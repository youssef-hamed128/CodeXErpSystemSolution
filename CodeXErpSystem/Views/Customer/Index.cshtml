@model IEnumerable<CodeXErpSystem.BLL.ViewModels.Customers.CustomerViewModel>
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>العملاء | CodeX Erp System</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css">
  <link rel="stylesheet" href="~/css/variables.css"><link rel="stylesheet" href="~/css/main.css"><link rel="stylesheet" href="~/css/layout.css"><link rel="stylesheet" href="~/css/components.css"><link rel="stylesheet" href="~/css/additions.css">
</head>
<body class="rtl">
<nav class="sidebar" id="sidebar">
  <a class="sidebar-brand" href="~/Home/Index"><div class="sidebar-brand-icon"><i class="fas fa-chart-line"></i></div><div class="sidebar-brand-text"><span class="sidebar-brand-name">CodeX Erp System</span></div></a>
  <div class="sidebar-nav-wrapper">      <ul class="sidebar-nav">
  <li class="nav-section-label">الرئيسية</li>
  <li class="nav-item"><a class="nav-link" href="~/Home/Index"><span class="nav-icon"><i class="fas fa-home"></i></span><span class="nav-text">الصفحة الرئيسية</span></a></li>
  
  <li class="nav-section-label">المبيعات</li>
  
  <li class="nav-item"><a class="nav-link" href="~/SalesInvoice/Index"><span class="nav-icon"><i class="fas fa-file-invoice-dollar"></i></span><span class="nav-text">فواتير المبيعات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/SalesReturn/Index"><span class="nav-icon"><i class="fas fa-undo"></i></span><span class="nav-text">مرتجعات المبيعات</span></a></li>

  <li class="nav-section-label">المشتريات</li>
  
  <li class="nav-item"><a class="nav-link" href="~/PurchaseInvoice/Index"><span class="nav-icon"><i class="fas fa-file-invoice"></i></span><span class="nav-text">فواتير المشتريات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/PurchaseReturn/Index"><span class="nav-icon"><i class="fas fa-undo-alt"></i></span><span class="nav-text">مرتجعات المشتريات</span></a></li>

  <li class="nav-section-label">المخزون</li>
  <li class="nav-item"><a class="nav-link" href="~/Inventory/Products"><span class="nav-icon"><i class="fas fa-box"></i></span><span class="nav-text">المنتجات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Inventory/Warehouses"><span class="nav-icon"><i class="fas fa-warehouse"></i></span><span class="nav-text">المستودعات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Inventory/StockTransfer"><span class="nav-icon"><i class="fas fa-exchange-alt"></i></span><span class="nav-text">نقل المخزون</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Inventory/StockAdjustment"><span class="nav-icon"><i class="fas fa-sliders-h"></i></span><span class="nav-text">تسوية المخزون</span></a></li>

  <li class="nav-section-label">المحاسبة</li>
  <li class="nav-item"><a class="nav-link" href="~/ChartOfAccounts/Index"><span class="nav-icon"><i class="fas fa-book"></i></span><span class="nav-text">دليل الحسابات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/JournalEntry/Index"><span class="nav-icon"><i class="fas fa-balance-scale"></i></span><span class="nav-text">القيود اليومية</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Payment/Index"><span class="nav-icon"><i class="fas fa-money-check-alt"></i></span><span class="nav-text">المدفوعات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Customer/Index"><span class="nav-icon"><i class="fas fa-users"></i></span><span class="nav-text">العملاء</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Supplier/Index"><span class="nav-icon"><i class="fas fa-truck"></i></span><span class="nav-text">الموردون</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Expense/Index"><span class="nav-icon"><i class="fas fa-receipt"></i></span><span class="nav-text">المصروفات</span></a></li>

  <li class="nav-section-label">التقارير</li>
  <li class="nav-item"><a class="nav-link" href="~/Reports/Index"><span class="nav-icon"><i class="fas fa-chart-line"></i></span><span class="nav-text">مركز التقارير</span></a></li>

  <li class="nav-section-label">الإعدادات</li>
  <li class="nav-item"><a class="nav-link" href="~/Users/Index"><span class="nav-icon"><i class="fas fa-users-cog"></i></span><span class="nav-text">المستخدمين والصلاحيات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Settings/Index"><span class="nav-icon"><i class="fas fa-cogs"></i></span><span class="nav-text">إعدادات النظام</span></a></li>
</ul>
</div>
</nav>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<div class="main-wrapper" id="mainWrapper">
  <header class="navbar"><div class="navbar-start"><button class="sidebar-toggle-btn" id="sidebarToggle"><i class="fas fa-bars"></i></button></div><div class="navbar-end"><div class="lang-switcher"><button class="lang-btn active" data-lang="ar">عربي</button></div><button class="theme-toggle navbar-btn" id="themeToggle"><i class="fas fa-moon"></i></button></div></header>

  <main class="content-wrapper">
    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item active">العملاء</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-users" style="color:var(--primary);"></i> إدارة العملاء</h1></div>
      <div class="page-header-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> تصدير</button>
        <button class="btn btn-primary" onclick="openModal('addCustomerModal')"><i class="fas fa-plus"></i> إضافة عميل</button>
      </div>
    </div>
    
    <div class="stats-grid">
      <div class="card" style="padding:var(--spacing-4);">
        <div style="font-size:var(--fs-sm);color:var(--text-secondary);"><i class="fas fa-users"></i> إجمالي العملاء</div>
        <div style="font-size:var(--fs-2xl);font-weight:700;margin-top:var(--spacing-2);">145</div>
      </div>
      <div class="card" style="padding:var(--spacing-4);">
        <div style="font-size:var(--fs-sm);color:var(--text-secondary);"><i class="fas fa-hand-holding-usd"></i> إجمالي الذمم المدينة</div>
        <div style="font-size:var(--fs-2xl);font-weight:700;margin-top:var(--spacing-2);color:var(--primary);">325,000 ر.س</div>
      </div>
      <div class="card" style="padding:var(--spacing-4);">
        <div style="font-size:var(--fs-sm);color:var(--text-secondary);"><i class="fas fa-exclamation-triangle"></i> ديون متأخرة</div>
        <div style="font-size:var(--fs-2xl);font-weight:700;margin-top:var(--spacing-2);color:var(--danger);">45,200 ر.س</div>
      </div>
    </div>

    <div class="data-table-wrapper">
      <div class="filter-bar">
        <input type="text" class="form-control" placeholder="بحث باسم العميل، الهاتف، أو الرقم الضريبي..." style="max-width:320px;">
        <select class="form-select"><option value="">جميع الحالات</option><option>نشط</option><option>متوقف</option></select>
      </div>
      <div class="table-responsive">
        <table class="data-table">
          <thead><tr><th>اسم العميل</th><th>رقم الهاتف</th><th>المدينة</th><th>الرصيد الحالي</th><th>الحد الائتماني</th><th>آخر فاتورة</th><th>الحالة</th><th class="center">الإجراءات</th></tr></thead>
          <tbody>
@foreach(var item in Model) {
            <tr>
              <td><div style="font-weight:600;color:var(--text-primary);">@item.Name</div><div style="font-size:var(--fs-xs);color:var(--text-muted);">الرقم الضريبي: @item.TaxNumber</div></td>
              <td dir="ltr" style="text-align:right;">@item.Phone</td><td>@item.Address</td><td class="numeric" style="color:var(--primary);font-weight:700;">@item.Balance.ToString("N2")</td><td class="numeric">@item.CreditLimit.ToString("N2")</td><td>@(item.UpdatedAt?.ToString("dd MMMM yyyy") ?? item.CreatedAt.ToString("dd MMMM yyyy"))</td><td><span class="badge @(item.IsDeleted ? "badge-danger" : "badge-success")">@(item.IsDeleted ? "متوقف" : "نشط")</span></td>
              <td class="table-actions"><button class="action-btn view" onclick="showPreview('معاينة السجل')"><i class="fas fa-eye"></i></button><button class="action-btn edit" onclick="openEditModal(@item.Id, '@item.Name', '@item.Phone', '', '@item.Address', '@item.TaxNumber', '@item.CreditLimit')"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteRecord(@item.Id)"><i class="fas fa-trash"></i></button></td>
            </tr>
}
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- Add Customer Modal -->
<div class="modal-overlay" id="addCustomerModal">
  <div class="modal modal-lg">
    <div class="modal-header"><h5 class="modal-title"><i class="fas fa-user-plus"></i> إضافة عميل جديد</h5><button class="modal-close" data-modal-close="addCustomerModal"><i class="fas fa-times"></i></button></div>
    <form id="customerForm">
      <input type="hidden" name="Id" id="customerId" value="0" />
      <div class="modal-body">
        @Html.AntiForgeryToken()
        <div class="tabs" data-tab-group="custTabs">
          <button type="button" class="tab active" data-tab="basicInfo">البيانات الأساسية</button>
          <button type="button" class="tab" data-tab="billingInfo">بيانات الفوترة والضريبة</button>
        </div>
        
        <div class="tab-panel active" id="basicInfo">
          <div class="form-grid-2">
            <div class="form-group"><label class="form-label required">اسم العميل / الشركة</label><input type="text" class="form-control" name="Name" required></div>
            <div class="form-group"><label class="form-label required">رقم الهاتف الأساسي</label><input type="tel" class="form-control" name="Phone" dir="ltr" required></div>
            <div class="form-group"><label class="form-label">البريد الإلكتروني</label><input type="email" class="form-control" name="Email" dir="ltr"></div>
            <div class="form-group"><label class="form-label">المدينة</label><input type="text" class="form-control" name="Address"></div>
          </div>
        </div>

        <div class="tab-panel" id="billingInfo">
          <div class="form-grid-2">
            <div class="form-group"><label class="form-label">الرقم الضريبي (VAT)</label><input type="text" class="form-control" name="TaxNumber" dir="ltr" maxlength="15"></div>
            <div class="form-group"><label class="form-label">الحد الائتماني (ر.س)</label><input type="number" class="form-control" name="CreditLimit" value="0"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ العميل</button>
        <button type="button" class="btn btn-secondary" data-modal-close="addCustomerModal">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/app.js"></script><script src="~/js/datatable.js"></script>
<script>
    function openEditModal(id, name, phone, email, address, taxNumber, creditLimit) {
        document.getElementById('customerForm').reset();
        document.getElementById('customerId').value = id;
        document.querySelector('input[name="Name"]').value = name;
        document.querySelector('input[name="Phone"]').value = phone;
        document.querySelector('input[name="Email"]').value = email;
        document.querySelector('input[name="Address"]').value = address;
        document.querySelector('input[name="TaxNumber"]').value = taxNumber;
        document.querySelector('input[name="CreditLimit"]').value = creditLimit;
        openModal('addCustomerModal');
    }

    function deleteRecord(id) {
        if(confirm('هل أنت متأكد من حذف هذا السجل؟')) {
            $.post('/Customer/Delete', { id: id }, function(res) {
                if(res.success) {
                    showToast(res.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(res.message, 'error');
                }
            });
        }
    }

    $('#customerForm').on('submit', function(e) {
        e.preventDefault();
        let id = $('#customerId').val();
        let url = id == 0 ? '/Customer/Create' : '/Customer/Edit';
        $.post(url, $(this).serialize(), function(res) {
            if(res.success) {
                showToast(res.message, 'success');
                closeModal('addCustomerModal');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(res.message, 'error');
            }
        });
    });
</script>
</body>
</html>


