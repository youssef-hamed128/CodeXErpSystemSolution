@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>تسجيل الدخول | CodeX Erp System</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css">
  <link rel="stylesheet" href="~/css/variables.css"><link rel="stylesheet" href="~/css/main.css"><link rel="stylesheet" href="~/css/components.css">
  <style>
    body {
      background: var(--bg-hover);
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
      margin: 0;
    }
    .login-card {
      background: var(--bg-card);
      width: 100%;
      max-width: 420px;
      padding: var(--spacing-6) var(--spacing-8);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-xl);
      text-align: center;
    }
    .login-logo {
      font-size: 48px;
      color: var(--primary);
      margin-bottom: var(--spacing-2);
    }
    .login-title {
      font-size: var(--fs-xl);
      font-weight: 700;
      margin-bottom: var(--spacing-2);
    }
    .login-subtitle {
      color: var(--text-secondary);
      font-size: var(--fs-sm);
      margin-bottom: var(--spacing-6);
    }
    .form-group {
      text-align: right;
      margin-bottom: var(--spacing-4);
    }
    .login-btn {
      width: 100%;
      padding: var(--spacing-3);
      font-size: var(--fs-base);
      margin-top: var(--spacing-4);
    }
    .forgot-password {
      display: block;
      margin-top: var(--spacing-4);
      font-size: var(--fs-sm);
      color: var(--primary);
      text-decoration: none;
    }
    .forgot-password:hover { text-decoration: underline; }
  </style>
</head>
<body class="rtl">
  <div class="login-card">
    <div class="login-logo"><i class="fas fa-chart-line"></i></div>
    <div class="login-title">CodeX Erp System</div>
    <div class="login-subtitle">نظام المحاسبة المتكامل</div>
    
    <form action="~/Home/Index" method="GET">
      <div class="form-group">
        <label class="form-label">اسم المستخدم</label>
        <div class="input-group">
          <span class="input-group-text" style="background:var(--bg-card);"><i class="fas fa-user"></i></span>
          <input type="text" class="form-control" placeholder="أدخل اسم المستخدم" required>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">كلمة المرور</label>
        <div class="input-group">
          <span class="input-group-text" style="background:var(--bg-card);"><i class="fas fa-lock"></i></span>
          <input type="password" class="form-control" placeholder="أدخل كلمة المرور" required>
        </div>
      </div>
      
      <div style="display:flex; justify-content:space-between; align-items:center; margin-top:var(--spacing-2); font-size:var(--fs-sm);">
        <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
          <input type="checkbox"> تذكرني
        </label>
      </div>

      <button type="submit" class="btn btn-primary login-btn">تسجيل الدخول <i class="fas fa-sign-in-alt" style="margin-right:8px;"></i></button>
      
      <a href="#" class="forgot-password">هل نسيت كلمة المرور؟</a>
    </form>
  </div>
</body>
</html>
