@using CodeXErpSystem.DAL.Entites.Enums
@model IEnumerable<CodeXErpSystem.BLL.ViewModels.Products.ProductViewModel>
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item active">المنتجات</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-boxes" style="color:var(--info);"></i> المنتجات وإدارة المخزون</h1><p style="color:var(--text-muted);font-size:var(--fs-sm);margin-top:4px;">إدارة المنتجات والأصناف ومستويات المخزون</p></div>
      <div class="page-header-right">
        <a href="~/Inventory/StockTransfer" class="btn btn-outline-secondary btn-sm"><i class="fas fa-exchange-alt"></i> تحويل مخزون</a>
        <a href="~/Inventory/StockAdjustment" class="btn btn-outline-secondary btn-sm"><i class="fas fa-sliders-h"></i> تسوية المخزون</a>
        <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel('productsTable')"><i class="fas fa-file-excel"></i> Excel</button>
        <button class="btn btn-primary" onclick="openModal('addCategoryModal')"><i class="fas fa-tags"></i> إضافة مجموعة جديدة</button>
        <button class="btn btn-info" onclick="openModal('addProductModal')"><i class="fas fa-plus"></i> منتج جديد</button>
      </div>
    </div>

    <!-- KPIs removed -->

    <div class="data-table-wrapper">
      <div class="filter-bar">
        <input type="text" class="form-control" placeholder="بحث بالاسم أو الكود (SKU)..." data-table-search-simple="productsTable" style="max-width:280px;">
        <select class="form-select" id="categoryFilter">
            <option value="">جميع الفئات</option>
            @if (ViewBag.Categories != null)
            {
                foreach(var cat in ViewBag.Categories as IEnumerable<CodeXErpSystem.DAL.Entites.ProductCategory>)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            }
        </select>
        <button class="btn btn-outline-secondary btn-sm" onclick="showToast('جارٍ فتح الفلتر المتقدم...', 'info')"><i class="fas fa-filter"></i> فلتر متقدم</button>
      </div>
      <div class="table-responsive">
        <table class="data-table" id="productsTable">
          <thead>
            <tr>
              <th class="table-checkbox"><input type="checkbox"></th>
              <th>الكود (SKU)</th><th>اسم المنتج</th><th>الفئة</th><th>المستودع</th><th>الوحدة</th>
              <th>تكلفة الوحدة</th><th>سعر البيع</th><th>الكمية المتاحة</th><th>الحد الأدنى</th>
              <th>الحالة</th><th class="center">الإجراءات</th>
            </tr>
          </thead>
          <tbody>
            @if (Model != null)
            {
                foreach(var product in Model)
                {
                    var trStyle = product.Status == "نفذت الكمية" ? "background:rgba(200,30,30,0.04);" : (product.Status != "متاح" ? "background:rgba(194,120,3,0.04);" : "");
                    var badgeClass = product.Status == "نفذت الكمية" ? "badge-danger" : (product.Status != "متاح" ? "badge-warning" : "badge-success");
                    var qtyColor = product.Status == "نفذت الكمية" ? "color:var(--danger);font-weight:700;" : (product.Status != "متاح" ? "color:var(--warning);font-weight:700;" : "color:var(--success);");
                <tr style="@trStyle">
                  <td class="table-checkbox"><input type="checkbox"></td>
                  <td style="font-family:monospace;font-weight:600;color:var(--text-muted);">@product.SKU</td>
                  <td style="font-weight:500;">@product.ProductName</td>
                  <td>@product.Category</td>
                  <td><span class="badge badge-info" style="background:rgba(23, 162, 184, 0.1); color:var(--info);">@product.WarehouseName</span></td>
                  <td>@product.Unit</td>
                  <td class="numeric">@product.UnitCost.ToString("N2")</td>
                  <td class="numeric" style="color:var(--success);font-weight:600;">@product.SalePrice.ToString("N2")</td>
                  <td class="numeric" style="@qtyColor">@product.AvailableQuantity</td>
                  <td class="numeric">@product.MinQuantity</td>
                  <td><span class="badge @badgeClass">@product.Status</span></td>
                  <td class="table-actions">
                    <button class="action-btn edit" onclick="openEditModal(@product.Id, '@product.ProductName', '@product.SKU', '@product.CategoryId', '@product.UnitCost', '@product.SalePrice', '@product.MinQuantity', '@product.Unit', '@product.TaxRate', '@product.Barcode')"><i class="fas fa-edit"></i></button>
                    <button class="action-btn delete" onclick="deleteRecord(@product.Id)"><i class="fas fa-trash"></i></button>
                  </td>
                </tr>
                }
            }
          </tbody>
        </table>
      </div>
      <div class="pagination"><div class="pagination-info">عرض 1 - 10 من 10 سجل</div><div class="pagination-controls"><button class="page-btn" disabled><i class="fas fa-chevron-right"></i></button><button class="page-btn active">1</button><button class="page-btn"><i class="fas fa-chevron-left"></i></button></div></div>
    </div>
  <!-- Add / Edit Product Modal -->
<div class="modal-overlay" id="addProductModal">
  <div class="modal modal-lg">
    <div class="modal-header"><h5 class="modal-title"><i class="fas fa-box"></i> إضافة / تعديل منتج</h5><button class="modal-close" data-modal-close="addProductModal"><i class="fas fa-times"></i></button></div>
    <form id="productForm" method="post">
    <input type="hidden" name="Id" id="productId" value="0" />
    <div class="modal-body" data-tab-group="productTabs">
      <!-- Tabs -->
      <div class="tabs">
        <button type="button" class="tab active" data-tab="basicTab">البيانات الأساسية</button>
        <button type="button" class="tab" data-tab="pricingTab">التسعير والمخزون</button>
      </div>

      <div class="tab-panel active" id="basicTab">
        <div class="form-grid-2" style="margin-top:var(--spacing-4);">
          <div class="form-group"><label class="form-label required">اسم المنتج</label><input type="text" class="form-control" name="Name" data-val="true" data-val-required="الاسم مطلوب" required></div>
          <div class="form-group"><label class="form-label required">كود المنتج (SKU)</label><input type="text" class="form-control" name="Code" placeholder="LAP-001" dir="ltr" required></div>
          <div class="form-group"><label class="form-label">الباركود</label><input type="text" class="form-control" name="Barcode" dir="ltr"></div>
          
          <div class="form-group">
              <label class="form-label required">الفئة</label>
              <select class="form-select" name="CategoryId" required>
                  <option value="">-- اختر الفئة --</option>
                  @if (ViewBag.Categories != null)
                  {
                      foreach(var cat in ViewBag.Categories as IEnumerable<CodeXErpSystem.DAL.Entites.ProductCategory>)
                      {
                          <option value="@cat.Id">@cat.Name</option>
                      }
                  }
              </select>
          </div>
          
          <div class="form-group"><label class="form-label">وحدة القياس</label><select class="form-select" name="UnitOfMeasure"><option value="Piece">قطعة</option><option value="Box">علبة</option><option value="Ream">رزمة</option><option value="Meter">متر</option><option value="Kg">كيلوجرام</option></select></div>
          <div class="form-group" style="grid-column:span 2;"><label class="form-label">الوصف</label><textarea class="form-control" name="Description" rows="2" placeholder="وصف تفصيلي للمنتج..."></textarea></div>
          <div class="form-group"><label class="form-label">الحالة</label><select class="form-select" name="IsActive"><option value="true" selected>نشط</option><option value="false">غير نشط</option></select></div>
        </div>
      </div>

      <div class="tab-panel" id="pricingTab">
        <div class="form-grid-2" style="margin-top:var(--spacing-4);">
          <div class="form-group"><label class="form-label required">تكلفة الوحدة</label><div class="input-group"><input type="number" class="form-control" name="PurchasePrice" value="0" min="0" step="0.01" required><span class="input-group-text">ج.م</span></div></div>
          <div class="form-group"><label class="form-label required">سعر البيع</label><div class="input-group"><input type="number" class="form-control" name="SalePrice" value="0" min="0" step="0.01" required><span class="input-group-text">ج.م</span></div></div>
          <div class="form-group"><label class="form-label">نسبة الضريبة (%)</label><input type="number" class="form-control" name="TaxRate" value="0" min="0" max="100" step="0.01"></div>
          <div class="form-group"><label class="form-label">الحد الأدنى للتنبيه</label><input type="number" class="form-control" name="MinStockLevel" value="0" min="0"></div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button type="submit" class="btn btn-info"><i class="fas fa-save"></i> حفظ المنتج</button>
      <button type="button" class="btn btn-secondary" data-modal-close="addProductModal">إلغاء</button>
    </div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="confirmModal"><div class="modal modal-sm"><div class="modal-header"><h5 class="modal-title" id="confirmModalTitle"></h5><button class="modal-close" data-modal-close="confirmModal"><i class="fas fa-times"></i></button></div><div class="modal-body" style="text-align:center;padding:var(--spacing-8);"><div class="confirm-icon danger" id="confirmIcon"><i class="fas fa-trash"></i></div><p id="confirmMessage"></p></div><div class="modal-footer" style="justify-content:center;"><button class="btn btn-secondary" data-modal-close="confirmModal" id="confirmCancelBtn">إلغاء</button><button class="btn btn-danger" id="confirmOkBtn">تأكيد الحذف</button></div></div></div>
<div class="modal-overlay" id="addCategoryModal">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h5 class="modal-title"><i class="fas fa-tags"></i> مجموعات الأصناف</h5>
      <button class="modal-close" data-modal-close="addCategoryModal"><i class="fas fa-times"></i></button>
    </div>
    <form id="categoryForm">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label required">اسم المجموعة</label>
          <input type="text" name="Name" class="form-control" required placeholder="أدخل اسم المجموعة...">
        </div>
        <div class="form-group">
          <label class="form-label">الوصف</label>
          <textarea name="Description" class="form-control" rows="3" placeholder="وصف المجموعة (اختياري)"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> حفظ المجموعة</button>
        <button type="button" class="btn btn-secondary" data-modal-close="addCategoryModal">إلغاء</button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
<script>
    var currentDeleteId = 0;
    
    function deleteRecord(id) {
        currentDeleteId = id;
        document.getElementById('confirmMessage').innerText = 'هل أنت متأكد من حذف المنتج؟';
        openModal('confirmModal');
    }

    // Category Filter Logic
    $('#categoryFilter').on('change', function() {
        var selectedText = $(this).find("option:selected").text().toLowerCase();
        var selectedValue = $(this).val();
        
        $('#productsTable tbody tr').filter(function() {
            if (!selectedValue) {
                $(this).show();
            } else {
                // The category name is in the 4th column (index 3)
                var categoryCell = $(this).find('td:eq(3)').text().toLowerCase().trim();
                $(this).toggle(categoryCell === selectedText);
            }
        });
    });

    document.getElementById('confirmOkBtn').addEventListener('click', function () {
        if (currentDeleteId > 0) {
            $.ajax({
                url: '/Product/Delete/' + currentDeleteId,
                type: 'POST',
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        closeModal('confirmModal');
                        setTimeout(() => location.reload(), 1000);
                    }
                }
            });
        }
    });

    $('#productForm').on('submit', function (e) {
        e.preventDefault();

        var url = $('#productId').val() == 0
            ? '/Product/Create'
            : '/Product/Edit';

        $.ajax({
            url: url,
            type: 'POST',
            data: $(this).serialize(),
            success: function (res) {
                if (res.success) {
                    showToast(res.message, 'success');
                    closeModal('addProductModal');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(res.message, 'error');
                }
            },
            error: function (xhr) {
                showToast('حدث خطأ أثناء الحفظ', 'error');
            }
        });
    });
    
    function openEditModal(id, name, code, categoryId, purchasePrice, salePrice, minStock, unit, taxRate, barcode) {
        document.getElementById('productForm').reset();
        document.getElementById('productId').value = id;
        document.querySelector('input[name="Name"]').value = name;
        document.querySelector('input[name="Code"]').value = code;
        document.querySelector('input[name="PurchasePrice"]').value = purchasePrice;
        document.querySelector('input[name="SalePrice"]').value = salePrice;
        document.querySelector('input[name="MinStockLevel"]').value = minStock;
        
        if (categoryId && categoryId !== 'null') document.querySelector('select[name="CategoryId"]').value = categoryId;
        if (unit && unit !== 'null') document.querySelector('select[name="UnitOfMeasure"]').value = unit;
        if (taxRate && taxRate !== 'null') document.querySelector('input[name="TaxRate"]').value = taxRate;
        if (barcode && barcode !== 'null' && barcode !== '') document.querySelector('input[name="Barcode"]').value = barcode;
        
        openModal('addProductModal');
    }

    $('#categoryForm').on('submit', function(e) {
         e.preventDefault();
         $.ajax({
             url: '/Product/CreateCategory',
             type: 'POST',
             data: $(this).serialize(),
             success: function(res) {
                 if (res.success) {
                     showToast(res.message, 'success');
                     closeModal('addCategoryModal');
                     // Add the new category to the dropdowns
                     var newOption = new Option(res.name, res.id);
                     $('select[name="CategoryId"]').append(newOption);
                     $('.filter-bar select:first').append(new Option(res.name, res.id));
                     document.getElementById('categoryForm').reset();
                 } else {
                     showToast(res.message, 'error');
                 }
             },
             error: function() {
                 showToast('حدث خطأ أثناء الاتصال بالخادم', 'error');
             }
         });
    });
</script>
}
