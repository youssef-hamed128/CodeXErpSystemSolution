@model IEnumerable<CodeXErpSystem.BLL.ViewModels.Expenses.ExpenseViewModel>
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item active">المصروفات</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-receipt" style="color:var(--danger);"></i> إدارة المصروفات</h1></div>
      <div class="page-header-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> تصدير</button>
        <button class="btn btn-primary" onclick="openModal('addExpenseModal')"><i class="fas fa-plus"></i> تسجيل مصروف</button>
      </div>
    </div>
    
@*     <div class="stats-grid">
      <div class="card" style="padding:var(--spacing-4);">
        <div style="font-size:var(--fs-sm);color:var(--text-secondary);"><i class="fas fa-calendar-alt"></i> مصروفات هذا الشهر</div>
        <div style="font-size:var(--fs-2xl);font-weight:700;margin-top:var(--spacing-2);color:var(--danger);">12,450 ج.م</div>
      </div>
    </div> *@

    <div class="data-table-wrapper">
      <div class="filter-bar">
        <input type="text" class="form-control" placeholder="بحث بالوصف..." style="max-width:280px;">
        <select class="form-select"><option value="">جميع التصنيفات</option><option>صيانة</option><option>ضيافة ومكتب</option><option>نثريات</option></select>
        <input type="date" class="form-control">
      </div>
      <div class="table-responsive">
        <table class="data-table">
          <thead><tr><th>رقم المصروف</th><th>التاريخ</th><th>التصنيف</th><th>الوصف</th><th>المبلغ</th><th>الاعتماد</th><th>الحالة</th><th class="center">الإجراءات</th></tr></thead>
          <tbody>
@foreach(var item in Model) {
            <tr>
              <td>@item.Id</td>
              <td>@item.Date.ToString("dd MMMM yyyy")</td>
              <td>@item.Category</td>
              <td>@item.Description</td>
              <td class="numeric" style="font-weight:700;color:var(--danger);">@item.Amount.ToString("N2")</td>
              <td>@item.PaymentMethod</td>
              <td><span class="badge @(false ? "badge-danger" : "badge-success")">@(false ? "متوقف" : "نشط")</span></td>
              <td class="table-actions"><button class="action-btn edit" onclick="openEditModal(@item.Id, '@item.Date.ToString("yyyy-MM-dd")', '@item.Category', @item.Amount, '@item.Description', '@item.PaymentMethod')"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteRecord(@item.Id)"><i class="fas fa-trash"></i></button></td>
            </tr>
}
          </tbody>
        </table>
      </div>
    </div>
  <!-- Add Expense Modal -->
<div class="modal-overlay" id="addExpenseModal">
  <div class="modal modal-md">
    <div class="modal-header"><h5 class="modal-title"><i class="fas fa-plus"></i> تسجيل مصروف جديد</h5><button class="modal-close" data-modal-close="addExpenseModal"><i class="fas fa-times"></i></button></div>
    <form id="expenseForm">
      <input type="hidden" name="Id" id="expenseId" value="0" />
      <div class="modal-body">
        @Html.AntiForgeryToken()
        <div class="form-group"><label class="form-label required">التاريخ</label><input type="date" class="form-control" name="Date" id="expDate" required></div>
        <div class="form-group"><label class="form-label required">التصنيف / الحساب</label><select class="form-select" name="Category"><option>-- اختر --</option><option value="صيانة">مصروفات صيانة وإصلاح</option><option value="ضيافة">مصروفات بوفيه وضيافة</option><option value="نثريات">مصروفات نثريات</option></select></div>
        <div class="form-group"><label class="form-label required">المبلغ (ج.م)</label><input type="number" class="form-control" name="Amount" value="0" required></div>
        <div class="form-group"><label class="form-label required">طريقة الدفع</label>
          <select class="form-select" name="PaymentMethod" required>
            <option value="Cash">نقدي</option>
            <option value="BankTransfer">تحويل بنكي</option>
            <option value="CreditCard">بطاقة ائتمان</option>
            <option value="Cheque">شيك</option>
          </select>
        </div>
        <div class="form-group"><label class="form-label required">الوصف والبيان</label><textarea class="form-control" name="Description" rows="2"></textarea></div>
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button>
        <button type="button" class="btn btn-secondary" data-modal-close="addExpenseModal">إلغاء</button>
      </div>
    </form>
  </div>
</div>


@section Scripts {
<script>
document.getElementById('expDate').value = new Date().toISOString().split('T')[0];
    function openEditModal(id, date, category, amount, description, paymentMethod) {
        document.getElementById('expenseForm').reset();
        document.getElementById('expenseId').value = id;
        document.querySelector('input[name="Date"]').value = date;
        document.querySelector('select[name="Category"]').value = category;
        document.querySelector('input[name="Amount"]').value = amount;
        document.querySelector('select[name="PaymentMethod"]').value = paymentMethod;
        document.querySelector('textarea[name="Description"]').value = description;
        openModal('addExpenseModal');
    }

    function deleteRecord(id) {
        if(confirm('هل أنت متأكد من حذف هذا السجل؟')) {
            $.post('/Expense/Delete', { id: id }, function(res) {
                if(res.success) {
                    showToast(res.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(res.message, 'error');
                }
            });
        }
    }

    $('#expenseForm').on('submit', function(e) {
        e.preventDefault();
        let id = $('#expenseId').val();
        let url = id == 0 ? '/Expense/Create' : '/Expense/Edit';
        $.post(url, $(this).serialize(), function(res) {
            if(res.success) {
                showToast(res.message, 'success');
                closeModal('addExpenseModal');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(res.message, 'error');
            }
        });
    });
</script>
}

