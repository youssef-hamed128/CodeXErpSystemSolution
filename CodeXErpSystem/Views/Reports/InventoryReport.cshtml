@model CodeXErpSystem.BLL.ViewModels.Reports.InventoryReportViewModel
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item"><a href="~/Reports/Index">التقارير</a></div><div class="breadcrumb-item active">قيمة المخزون</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-boxes" style="color:var(--info);"></i> تقرير قيمة المخزون</h1></div>
      <div class="page-header-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel('reportTable')"><i class="fas fa-file-excel"></i> تصدير Excel</button>
        <button class="btn btn-primary" onclick="window.print()"><i class="fas fa-print"></i> طباعة</button>
      </div>
    </div>

    <!-- Chart -->
    <div class="card" style="margin-bottom:var(--spacing-5);">
      <div class="chart-header"><h3 class="chart-title">أعلى 5 منتجات قيمةً في المخزون</h3></div>
      <div class="chart-container" style="height:300px;"><canvas id="reportChart"></canvas></div>
    </div>

    <!-- Table -->
    <div class="data-table-wrapper">
      <div class="table-responsive">
        <table class="data-table" id="reportTable">
          <thead><tr><th>كود المنتج</th><th>اسم المنتج</th><th>الكمية الحالية</th><th>تكلفة الوحدة (ج.م)</th><th>القيمة الإجمالية (ج.م)</th></tr></thead>
          <tbody>
            @foreach(var item in Model.Items) {
            <tr>
              <td dir="ltr" style="text-align:right;">@item.Code</td>
              <td>@item.Name</td>
              <td class="numeric">@item.Quantity</td>
              <td class="numeric">@item.UnitCost.ToString("N2")</td>
              <td class="numeric" style="font-weight:700;">@item.TotalValue.ToString("N2")</td>
            </tr>
            }
            @if(!Model.Items.Any()) {
            <tr><td colspan="5" class="center">لا يوجد مخزون متاح</td></tr>
            }
            <tr style="background:var(--bg-active);font-weight:800;">
              <td colspan="4" style="text-align:left;">إجمالي قيمة المخزون</td>
              <td class="numeric" style="color:var(--primary);font-size:16px;">@Model.TotalInventoryValue.ToString("N2")</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
    
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        var topItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items.Take(5).Select(i => new { name = i.Name, value = i.TotalValue })));
        
        var ctx = document.getElementById('reportChart').getContext('2d');
        var reportChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: topItems.map(i => i.name),
                datasets: [{
                    label: 'القيمة الإجمالية',
                    data: topItems.map(i => i.value),
                    backgroundColor: '#1a56db'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                }
            }
        });
    </script>
}
