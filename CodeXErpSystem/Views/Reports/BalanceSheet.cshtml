@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item"><a href="~/Reports/Index">التقارير</a></div><div class="breadcrumb-item active">الميزانية العمومية</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-balance-scale" style="color:var(--primary);"></i> تقرير الميزانية العمومية</h1></div>
      <div class="page-header-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel('reportTable')"><i class="fas fa-file-excel"></i> تصدير Excel</button>
        <button class="btn btn-primary" onclick="window.print()"><i class="fas fa-print"></i> طباعة</button>
      </div>
    </div>
    
    <div class="card" style="padding:var(--spacing-4); margin-bottom:var(--spacing-5);">
      <div class="form-grid-2">
        <div class="form-group"><label class="form-label">كما في تاريخ</label><input type="date" class="form-control" value="2024-12-31"></div>
        <div class="form-group" style="display:flex;align-items:flex-end;"><button class="btn btn-primary" style="width:200px;" onclick="showToast('تم تحديث التقرير', 'success')"><i class="fas fa-filter"></i> تحديث التقرير</button></div>
      </div>
    </div>

    <!-- Chart -->
    <div class="card" style="margin-bottom:var(--spacing-5);">
      <div class="chart-header"><h3 class="chart-title">التوزيع المالي</h3></div>
      <div class="chart-container" style="height:300px;"><canvas id="reportChart"></canvas></div>
    </div>

    <!-- Table -->
    <div class="data-table-wrapper">
      <div class="table-responsive">
        <table class="data-table" id="reportTable">
          <thead><tr><th>البند</th><th>الأصول (ج.م)</th><th>الخصوم وحقوق الملكية (ج.م)</th></tr></thead>
          <tbody>
            <tr style="background:var(--bg-hover);font-weight:700;"><td colspan="3">الأصول المتداولة</td></tr>
            <tr><td style="padding-right:20px;">النقدية وما يعادلها</td><td class="numeric">150,000.00</td><td class="numeric">-</td></tr>
            <tr><td style="padding-right:20px;">الذمم المدينة</td><td class="numeric">45,000.00</td><td class="numeric">-</td></tr>
            <tr><td style="padding-right:20px;">المخزون</td><td class="numeric">80,000.00</td><td class="numeric">-</td></tr>
            <tr style="background:rgba(26,86,219,0.05);font-weight:700;"><td>إجمالي الأصول المتداولة</td><td class="numeric" style="color:var(--primary);">275,000.00</td><td class="numeric">-</td></tr>

            <tr style="background:var(--bg-hover);font-weight:700;"><td colspan="3">الخصوم</td></tr>
            <tr><td style="padding-right:20px;">الذمم الدائنة</td><td class="numeric">-</td><td class="numeric">60,000.00</td></tr>
            <tr style="background:rgba(225,29,72,0.05);font-weight:700;"><td>إجمالي الخصوم</td><td class="numeric">-</td><td class="numeric" style="color:var(--danger);">60,000.00</td></tr>

            <tr style="background:var(--bg-hover);font-weight:700;"><td colspan="3">حقوق الملكية</td></tr>
            <tr><td style="padding-right:20px;">رأس المال</td><td class="numeric">-</td><td class="numeric">150,000.00</td></tr>
            <tr><td style="padding-right:20px;">الأرباح المحتجزة</td><td class="numeric">-</td><td class="numeric">65,000.00</td></tr>
            <tr style="background:rgba(5,150,105,0.05);font-weight:700;"><td>إجمالي حقوق الملكية</td><td class="numeric">-</td><td class="numeric" style="color:var(--success);">215,000.00</td></tr>

            <tr style="background:var(--bg-active);font-weight:800;font-size:16px;">
              <td>الإجمالي الكلي</td>
              <td class="numeric" style="color:var(--primary);">275,000.00</td>
              <td class="numeric" style="color:var(--primary);">275,000.00</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  




