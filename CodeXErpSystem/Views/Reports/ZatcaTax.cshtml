@model CodeXErpSystem.BLL.ViewModels.Reports.ZatcaTaxViewModel
@{ Layout = "_Layout"; }

    <nav class="breadcrumb">
        <div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div>
        <div class="breadcrumb-item"><a href="~/Reports/Index">التقارير</a></div>
        <div class="breadcrumb-item active">التقارير الضريبية</div>
    </nav>
    <div class="page-header">
        <div class="page-header-left">
            <h1 class="page-title"><i class="fas fa-file-invoice" style="color:var(--danger);"></i> التقارير الضريبية</h1>
        </div>
        <div class="page-header-right">
            <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel('reportTable')"><i class="fas fa-file-excel"></i> تصدير Excel</button>
            <button class="btn btn-primary" onclick="window.print()"><i class="fas fa-print"></i> طباعة الإقرار</button>
        </div>
    </div>

    <form method="get" action="~/Reports/ZatcaTax">
        <div class="card" style="padding:var(--spacing-4); margin-bottom:var(--spacing-5);">
            <div class="form-grid-3">
                <div class="form-group">
                    <label class="form-label">من تاريخ</label>
                    <input type="date" name="startDate" class="form-control" value="@Model.StartDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="form-group">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date" name="endDate" class="form-control" value="@Model.EndDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="form-group" style="display:flex;align-items:flex-end;">
                    <button type="submit" class="btn btn-primary" style="width:200px;"><i class="fas fa-filter"></i> تحديث التقرير</button>
                </div>
            </div>
        </div>
    </form>

    <div class="card" style="padding:var(--spacing-5);">
        <h3 style="margin-bottom:var(--spacing-4); border-bottom:1px solid var(--border-color); padding-bottom:10px;">ملخص الإقرار الضريبي (VAT)</h3>
        
        <table class="data-table" id="reportTable" style="margin-bottom:var(--spacing-4);">
            <thead>
                <tr>
                    <th>البند</th>
                    <th>المبلغ الخاضع للضريبة (ج.م)</th>
                    <th>مبلغ الضريبة (ج.م)</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td style="font-weight:600;">المبيعات الخاضعة للضريبة الأساسية (المخرجات)</td>
                    <td class="numeric">@Model.TotalSales.ToString("N2")</td>
                    <td class="numeric text-danger">@Model.OutputTax.ToString("N2")</td>
                </tr>
                <tr>
                    <td style="font-weight:600;">المشتريات الخاضعة للضريبة الأساسية (المدخلات)</td>
                    <td class="numeric">@Model.TotalPurchases.ToString("N2")</td>
                    <td class="numeric text-success">@Model.InputTax.ToString("N2")</td>
                </tr>
                <tr style="background:var(--bg-active);font-weight:800;font-size:16px;">
                    <td>صافي الضريبة المستحقة / (المستردة)</td>
                    <td></td>
                    <td class="numeric" style="color:@(Model.NetTaxDue >= 0 ? "var(--danger)" : "var(--success)");">@Model.NetTaxDue.ToString("N2")</td>
                </tr>
            </tbody>
        </table>

        @if(Model.NetTaxDue > 0)
        {
            <div class="alert alert-danger" style="padding:15px; border-radius:8px; font-weight:bold; background-color:#fee2e2; color:#b91c1c;">
                <i class="fas fa-exclamation-circle"></i> صافي الضريبة المستحقة الدفع للهيئة: @Model.NetTaxDue.ToString("N2") ج.م
            </div>
        }
        else if (Model.NetTaxDue < 0)
        {
            <div class="alert alert-success" style="padding:15px; border-radius:8px; font-weight:bold; background-color:#d1fae5; color:#065f46;">
                <i class="fas fa-check-circle"></i> رصيد دائن (مسترد) من الهيئة: @Math.Abs(Model.NetTaxDue).ToString("N2") ج.م
            </div>
        }
        else
        {
            <div class="alert alert-info" style="padding:15px; border-radius:8px; font-weight:bold; background-color:#e0f2fe; color:#0369a1;">
                <i class="fas fa-info-circle"></i> لا توجد ضريبة مستحقة الدفع أو الاسترداد.
            </div>
        }
    </div>
