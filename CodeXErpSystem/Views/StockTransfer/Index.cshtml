@model CodeXErpSystem.BLL.ViewModels.Warehouses.StockTransferViewModel
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="../Home/Index.html"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item"><a href="../Product/Index">المخزون</a></div><div class="breadcrumb-item active">تحويل المخزون</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-exchange-alt" style="color:var(--primary);"></i> تحويل المخزون</h1></div>
    </div>
    
    <form id="transferForm">
      <input type="hidden" name="Id" id="TransferId" value="0" />
      <!-- @Html.AntiForgeryToken() -->
      <div class="invoice-layout">
        <div class="invoice-section">
          <div class="invoice-section-header"><i class="fas fa-info-circle"></i> بيانات التحويل</div>
          <div class="invoice-section-body">
            <div class="form-grid-2">
              <div class="form-group"><label class="form-label required">تاريخ التحويل</label><input type="date" class="form-control" name="TransferDate" id="transferDate" required></div>
              <div class="form-group"><label class="form-label">المرجع</label><input type="text" class="form-control" name="ReferenceNumber" placeholder="TRF-2024-001"></div>
              
              <div class="form-group">
                <label class="form-label required">من مستودع (المصدر)</label>
                <select class="form-select" name="FromWarehouseId" required>
                  <option value="">-- اختر المستودع --</option>
                  @foreach(var wh in Model.Warehouses)
                  {
                    <option value="@wh.Id">@wh.Name</option>
                  }
                </select>
              </div>
              
              <div class="form-group">
                <label class="form-label required">إلى مستودع (الوجهة)</label>
                <select class="form-select" name="ToWarehouseId" required>
                  <option value="">-- اختر المستودع --</option>
                  @foreach(var wh in Model.Warehouses) {
                    <option value="@wh.Id">@wh.Name</option>
                  }
                </select>
              </div>
            </div>
          </div>
        </div>

        <div class="invoice-section">
          <div class="invoice-section-header"><i class="fas fa-boxes"></i> المنتجات المحولة</div>
          <div class="invoice-section-body" style="padding:0;">
            <div class="table-responsive">
              <table class="invoice-items-table">
                <thead><tr><th style="width:40%;">المنتج</th><th style="width:20%;">الكمية المتاحة (المصدر)</th><th style="width:20%;">الكمية المحولة</th><th style="width:10%;" class="center">×</th></tr></thead>
                <tbody id="transferItemsBody">
                  @for(int i = 0; i < Model.TransferItems.Count(); i++) {
                    var item = Model.TransferItems.ElementAt(i);
                  <tr>
                    <td>
                      <select class="form-select mb-1 category-select" onchange="filterTransferProducts(this, 'trf_existing_@i')">
                         <option value="">-- كل المجموعات --</option>
                         @foreach(var cat in Model.Categories) {
                             <option value="@cat.Id">@cat.Name</option>
                         }
                      </select>
                      <select class="form-select product-select" name="TransferItems[@i].ProductId" id="trf_existing_@i" onchange="updateAvailableQuantity(this.id)" required>
                        @foreach(var p in Model.Products) {
                          if (p.Id == item.ProductId) {
                            <option value="@p.Id" selected>@p.ProductName</option>
                          } else {
                            <option value="@p.Id">@p.ProductName</option>
                          }
                        }
                      </select>
                    </td>
                    <td class="numeric available-qty">@item.AvailableQuantity</td>
                    <td><input type="number" class="form-control" name="TransferItems[@i].TransferredQuantity" value="@item.TransferredQuantity" min="1" max="@item.AvailableQuantity"></td>
                    <td class="center"><button type="button" class="remove-row-btn" onclick="const r = this.closest('tr'); if(r){r.style.opacity=0;setTimeout(()=>r.remove(),300);}"><i class="fas fa-trash"></i></button></td>
                  </tr>
                  }
                </tbody>
              </table>
            </div>
            <div style="padding:var(--spacing-4);"><button type="button" class="add-line-btn" id="addTransferLine"><i class="fas fa-plus"></i> إضافة منتج</button></div>
          </div>
        </div>

        <div class="invoice-section">
          <div class="invoice-section-header"><i class="fas fa-sticky-note"></i> الملاحظات</div>
          <div class="invoice-section-body">
            <div class="form-group"><textarea class="form-control" name="Notes" rows="3" placeholder="أسباب التحويل أو أي ملاحظات أخرى..."></textarea></div>
          </div>
        </div>
      </div>
      <div class="invoice-action-bar no-print">
        <button type="submit" class="btn btn-primary"><i class="fas fa-check"></i> تأكيد التحويل</button>
        <a href="../Product/Index" class="btn btn-ghost" style="margin-right:auto;">إلغاء</a>
      </div>
    </form>
  <div class="modal-overlay" id="confirmModal"><div class="modal modal-sm"><div class="modal-header"><h5 class="modal-title" id="confirmModalTitle"></h5><button class="modal-close" data-modal-close="confirmModal"><i class="fas fa-times"></i></button></div><div class="modal-body" style="text-align:center;padding:var(--spacing-8);"><div class="confirm-icon danger" id="confirmIcon"><i class="fas fa-trash"></i></div><p id="confirmMessage"></p></div><div class="modal-footer" style="justify-content:center;"><button class="btn btn-secondary" data-modal-close="confirmModal" id="confirmCancelBtn">إلغاء</button><button class="btn btn-danger" id="confirmOkBtn">تأكيد الحذف</button></div></div></div>
<div class="toast-container"></div>

@section Scripts {
<script>
    var currentDeleteId = 0;
    
    function deleteRow(btn, type, id) {
        currentDeleteId = id;
        document.getElementById('confirmMessage').innerText = 'هل أنت متأكد من حذف ' + type + '؟';
        openModal('confirmModal');
    }

    document.getElementById('confirmOkBtn').addEventListener('click', function () {
        if (currentDeleteId > 0) {
            $.ajax({
                url: '/StockTransfer/Delete/' + currentDeleteId,
                type: 'POST',
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        closeModal('confirmModal');
                        setTimeout(() => location.reload(), 1000);
                    }
                }
            });
        }
    });

    var productsList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Products));
    var categoriesList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Categories));
    
    var categoryOptions = categoriesList.map(c => `<option value="${c.Id}">${c.Name}</option>`).join('');

    let transferRowIndex = 0;

    $('#addTransferLine').on('click', function() {
        var trId = 'trf_row_' + transferRowIndex;
        var tr = `
            <tr>
                <td>
                    <select class="form-select mb-1" onchange="filterTransferProducts(this, '${trId}')">
                        <option value="">-- كل المجموعات --</option>
                        ${categoryOptions}
                    </select>
                    <select class="form-select product-select" name="TransferItems[].ProductId" id="${trId}" onchange="updateAvailableQuantity(this.id)" required>
                        <option value="">-- اختر المنتج --</option>
                        ${productsList.map(p => `<option value="${p.Id}">${p.ProductName}</option>`).join('')}
                    </select>
                </td>
                <td class="numeric available-qty">0</td>
                <td><input type="number" class="form-control" name="TransferItems[].TransferredQuantity" value="1" min="1"></td>
                <td class="center">
                    <button type="button" class="remove-row-btn" onclick="const r = this.closest('tr'); if(r){r.style.opacity=0;setTimeout(()=>r.remove(),300);}">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            </tr>
        `;
        $('#transferItemsBody').append(tr);
        transferRowIndex++;
    });

    function filterTransferProducts(categorySelect, productSelectId) {
        let categoryId = categorySelect.value;
        let productSelect = $('#' + productSelectId);
        
        productSelect.empty();
        productSelect.append(new Option("-- اختر المنتج --", "", true, true));
        
        let filteredProducts = productsList;
        if (categoryId) {
            filteredProducts = productsList.filter(p => p.CategoryId == categoryId);
        }
        
        filteredProducts.forEach(p => {
            productSelect.append(new Option(p.ProductName, p.Id, false, false));
        });
        updateAvailableQuantity(productSelectId);
    }

    function updateAvailableQuantity(selectId) {
        let sourceWarehouseId = $('select[name="FromWarehouseId"]').val();
        let productSelect = $('#' + selectId);
        let productId = productSelect.val();
        
        let qtyCell = productSelect.closest('tr').find('.available-qty');
        let qtyInput = productSelect.closest('tr').find('input[type="number"]');

        if (!sourceWarehouseId || !productId) {
            qtyCell.text('0');
            qtyInput.attr('max', '0');
            return;
        }

        let product = productsList.find(p => p.Id == productId);
        if (product && product.StockByWarehouse && product.StockByWarehouse[sourceWarehouseId] !== undefined) {
            let qty = product.StockByWarehouse[sourceWarehouseId];
            qtyCell.text(qty);
            qtyInput.attr('max', qty);
        } else {
            qtyCell.text('0');
            qtyInput.attr('max', '0');
        }
    }

    $('select[name="FromWarehouseId"]').on('change', function() {
        $('.product-select').each(function() {
            updateAvailableQuantity($(this).attr('id'));
        });
    });

    $('#transferForm').on('submit', function (e) {
        e.preventDefault();
        var data = {};
        $(this).serializeArray().forEach(item => {
            data[item.name] = item.value;
        });

        var url = data.Id == 0 ? '/StockTransfer/Create' : '/StockTransfer/Edit';
        
        $.ajax({
            url: url,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (res) {
                if (res.success) {
                    showToast(res.message, 'success');
                    setTimeout(() => window.location.href = '../Product/Index', 1500);
                }
            }
        });
    });
</script>
}
