@model IEnumerable<CodeXErpSystem.BLL.ViewModels.Accounting.JournalEntryViewModel>
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item active">القيود اليومية</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-book" style="color:var(--primary);"></i> القيود اليومية (دفتر اليومية)</h1></div>
      <div class="page-header-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel('jeTable')"><i class="fas fa-file-excel"></i> تصدير</button>
        <button class="btn btn-primary" onclick="openModal('addEntryModal')"><i class="fas fa-plus"></i> إنشاء قيد جديد</button>
      </div>
    </div>
    
    <div class="data-table-wrapper">
      <div class="filter-bar">
        <input type="text" class="form-control" placeholder="رقم القيد أو الوصف..." style="max-width:300px;">
        <input type="date" class="form-control">
        <select class="form-select"><option value="">جميع الحالات</option><option>مرحل</option><option>مسودة</option></select>
      </div>
      <div class="table-responsive">
        <table class="data-table" id="jeTable">
          <thead><tr><th>رقم القيد</th><th>التاريخ</th><th>الوصف</th><th>إجمالي المدين</th><th>إجمالي الدائن</th><th>الحالة</th><th class="center">الإجراءات</th></tr></thead>
          <tbody>
@foreach(var item in Model) {
            <tr>
              <td style="font-weight:600;color:var(--primary);">#@item.EntryNumber</td>
              <td>@item.Date.ToString("dd MMMM yyyy")</td>
              <td>@item.Description</td>
              <td class="numeric">0.00</td>
              <td class="numeric">0.00</td>
              <td><span class="badge @(item.Status == 0 ? "badge-warning" : "badge-success")">@(item.Status == 0 ? "مسودة" : "مرحل")</span></td>
              <td class="table-actions"><button class="action-btn edit" onclick="openEditModal(@item.Id, '@item.EntryNumber', '@item.Date.ToString("yyyy-MM-dd")', '@item.Description')"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteRecord(@item.Id)"><i class="fas fa-trash"></i></button><button class="action-btn view" onclick="showPreview('تفاصيل القيد')"><i class="fas fa-eye"></i></button></td>
            </tr>
}
          </tbody>
        </table>
      </div>
    </div>
  <!-- Add Journal Entry Modal -->
<div class="modal-overlay" id="addEntryModal">
  <div class="modal modal-lg">
    <div class="modal-header"><h5 class="modal-title"><i class="fas fa-plus"></i> قيد يومية جديد</h5><button class="modal-close" data-modal-close="addEntryModal"><i class="fas fa-times"></i></button></div>
    <form id="journalEntryForm">
      <input type="hidden" name="Id" id="journalEntryId" value="0" />
      <div class="modal-body">
        @Html.AntiForgeryToken()
        <div class="form-grid-2">
          <div class="form-group"><label class="form-label required">تاريخ القيد</label><input type="date" class="form-control" id="jeDate" name="Date" required></div>
          <div class="form-group"><label class="form-label">المرجع</label><input type="text" class="form-control" name="EntryNumber" required></div>
          <div class="form-group" style="grid-column:span 2;"><label class="form-label required">البيان / الوصف</label><input type="text" class="form-control" name="Description" placeholder="وصف العملية المالية..."></div>
        </div>
        
        <h6 style="margin:var(--spacing-4) 0 var(--spacing-3); font-weight:600;">تفاصيل القيد (أطراف القيد)</h6>
        <table class="invoice-items-table" style="border:1px solid var(--border-color);">
          <thead><tr><th>رقم الحساب</th><th>اسم الحساب</th><th>البيان</th><th>مدين (ج.م)</th><th>دائن (ج.م)</th><th>×</th></tr></thead>
          <tbody>
            <tr>
              <td><input type="text" class="form-control" value="1101"></td>
              <td><input type="text" class="form-control" value="النقدية بالصندوق"></td>
              <td><input type="text" class="form-control"></td>
              <td><input type="number" class="form-control" value="0"></td>
              <td><input type="number" class="form-control" value="0"></td>
              <td class="center"><button type="button" class="remove-row-btn" onclick="const r = this.closest('tr'); if(r){r.style.opacity=0;setTimeout(()=>r.remove(),300);}"><i class="fas fa-trash"></i></button></td>
            </tr>
          </tbody>
          <tfoot>
            <tr style="font-weight:700; background:var(--bg-hover);">
              <td colspan="3" style="text-align:left;">الإجمالي:</td>
              <td class="numeric">0.00</td>
              <td class="numeric">0.00</td>
              <td></td>
            </tr>
          </tfoot>
        </table>
        <button type="button" class="add-line-btn" style="margin-top:var(--spacing-2);" onclick="showToast('تمت الإضافة', 'success')"><i class="fas fa-plus"></i> إضافة طرف قيد</button>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" onclick="saveAsDraft(); closeModal('addEntryModal');">حفظ كمسودة</button>
        <button type="submit" class="btn btn-primary"><i class="fas fa-check"></i> ترحيل القيد</button>
        <button type="button" class="btn btn-secondary" data-modal-close="addEntryModal">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="confirmModal"><div class="modal modal-sm"><div class="modal-header"><h5 class="modal-title" id="confirmModalTitle"></h5><button class="modal-close" data-modal-close="confirmModal"><i class="fas fa-times"></i></button></div><div class="modal-body" style="text-align:center;padding:var(--spacing-8);"><div class="confirm-icon danger" id="confirmIcon"><i class="fas fa-trash"></i></div><p id="confirmMessage"></p></div><div class="modal-footer" style="justify-content:center;"><button class="btn btn-secondary" data-modal-close="confirmModal" id="confirmCancelBtn">إلغاء</button><button class="btn btn-danger" id="confirmOkBtn">تأكيد الحذف</button></div></div></div>
<div class="toast-container"></div>

@section Scripts {
<script>
document.getElementById('jeDate').value = new Date().toISOString().split('T')[0];
    function openEditModal(id, entryNumber, date, description) {
        document.getElementById('journalEntryForm').reset();
        document.getElementById('journalEntryId').value = id;
        document.querySelector('input[name="EntryNumber"]').value = entryNumber;
        document.querySelector('input[name="Date"]').value = date;
        document.querySelector('input[name="Description"]').value = description;
        openModal('addEntryModal');
    }

    function deleteRecord(id) {
        if(confirm('هل أنت متأكد من حذف هذا السجل؟')) {
            $.post('/JournalEntry/Delete', { id: id }, function(res) {
                if(res.success) {
                    showToast(res.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(res.message, 'error');
                }
            });
        }
    }

    $('#journalEntryForm').on('submit', function(e) {
        e.preventDefault();
        let id = $('#journalEntryId').val();
        let url = id == 0 ? '/JournalEntry/Create' : '/JournalEntry/Edit';
        $.post(url, $(this).serialize(), function(res) {
            if(res.success) {
                showToast(res.message, 'success');
                closeModal('addEntryModal');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(res.message, 'error');
            }
        });
    });
</script>
}

