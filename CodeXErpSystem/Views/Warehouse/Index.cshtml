@model IEnumerable<CodeXErpSystem.BLL.ViewModels.Warehouses.WarehouseViewModel>
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="../Home/Index.html"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item active">المستودعات</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-warehouse" style="color:var(--primary);"></i> إدارة المستودعات</h1></div>
      <div class="page-header-right">
        <button class="btn btn-primary" onclick="openAddWarehouseModal()"><i class="fas fa-plus"></i> إضافة مستودع جديد</button>
      </div>
    </div>
    
    <div class="grid-3">
      @foreach(var warehouse in Model)
      {
      <div class="card" style="padding:var(--spacing-5);">
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:var(--spacing-3);">
          <div style="display:flex; align-items:center; gap:var(--spacing-3);">
            <div style="width:48px; height:48px; border-radius:var(--radius-md); background:@warehouse.BgColor; color:@warehouse.TextColor; display:flex; align-items:center; justify-content:center; font-size:24px;"><i class="fas @warehouse.IconClass"></i></div>
            <div>
              <h3 style="font-size:var(--fs-lg); font-weight:700; margin:0;">@warehouse.Name</h3>
              <span class="badge @warehouse.StatusClass" style="font-size:10px;">@warehouse.Status</span>
            </div>
          </div>
          <div><button class="action-btn edit" onclick="editWarehouse(@warehouse.Id, '@(warehouse.Name?.Replace("'", "\\'"))', '@(warehouse.Code?.Replace("'", "\\'"))', '@(warehouse.Phone?.Replace("'", "\\'"))', '@(warehouse.Location?.Replace("'", "\\'"))', '@warehouse.IsActive.ToString().ToLower()')"><i class="fas fa-edit"></i></button></div>
        </div>
        <div style="font-size:var(--fs-sm); color:var(--text-secondary); margin-bottom:var(--spacing-4);">
          <div style="margin-bottom:4px;"><i class="fas fa-map-marker-alt" style="width:20px; text-align:center;"></i> @warehouse.Location</div>
          <div><i class="fas fa-phone" style="width:20px; text-align:center;"></i> @warehouse.Phone</div>
        </div>
        <div style="background:var(--bg-hover); padding:var(--spacing-3); border-radius:var(--radius-md); display:flex; justify-content:space-between; align-items:center;">
          <span style="font-size:var(--fs-sm); color:var(--text-muted);">إجمالي قيمة المخزون:</span>
          <span style="font-weight:700; font-size:var(--fs-base); color:var(--primary);">@warehouse.TotalInventoryValue.ToString("N2") ج.م</span>
        </div>
      </div>
      }
    </div>
  <!-- Add/Edit Warehouse Modal -->
<div class="modal-overlay" id="addWarehouseModal">
  <div class="modal modal-lg">
    <div class="modal-header"><h5 class="modal-title"><i class="fas fa-warehouse"></i> إضافة/تعديل مستودع</h5><button class="modal-close" data-modal-close="addWarehouseModal"><i class="fas fa-times"></i></button></div>
    <form id="warehouseForm">
    <input type="hidden" name="Id" id="WarehouseId" value="0" />
    <div class="modal-body">
      <div class="form-grid-2">
        <div class="form-group"><label class="form-label required">اسم المستودع</label><input type="text" class="form-control" name="Name" data-val="true" data-val-required="اسم المستودع مطلوب"></div>
        <div class="form-group"><label class="form-label required">الكود</label><input type="text" class="form-control" name="Code" dir="ltr" placeholder="WH-01"></div>
        <div class="form-group"><label class="form-label">رقم الهاتف</label><input type="tel" class="form-control" name="Phone"></div>
        <div class="form-group" style="grid-column:span 2;"><label class="form-label required">العنوان</label><textarea class="form-control" name="Address" rows="2"></textarea></div>
        <div class="form-group"><label class="form-label">الحالة</label><select class="form-select" name="IsActive"><option value="true" selected>نشط</option><option value="false">غير نشط</option></select></div>
      </div>
    </div>
    <div class="modal-footer">
      <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button>
      <button type="button" class="btn btn-secondary" data-modal-close="addWarehouseModal">إلغاء</button>
    </div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="confirmModal"><div class="modal modal-sm"><div class="modal-header"><h5 class="modal-title" id="confirmModalTitle"></h5><button class="modal-close" data-modal-close="confirmModal"><i class="fas fa-times"></i></button></div><div class="modal-body" style="text-align:center;padding:var(--spacing-8);"><div class="confirm-icon danger" id="confirmIcon"><i class="fas fa-trash"></i></div><p id="confirmMessage"></p></div><div class="modal-footer" style="justify-content:center;"><button class="btn btn-secondary" data-modal-close="confirmModal" id="confirmCancelBtn">إلغاء</button><button class="btn btn-danger" id="confirmOkBtn">تأكيد الحذف</button></div></div></div>
<div class="toast-container"></div>

@section Scripts {
<script>
    var currentDeleteId = 0;
    
    function deleteRow(btn, type, id) {
        currentDeleteId = id;
        document.getElementById('confirmMessage').innerText = 'هل أنت متأكد من حذف ' + type + '؟';
        openModal('confirmModal');
    }

    document.getElementById('confirmOkBtn').addEventListener('click', function () {
        if (currentDeleteId > 0) {
            $.ajax({
                url: '/Warehouse/Delete/' + currentDeleteId,
                type: 'POST',
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        closeModal('confirmModal');
                        setTimeout(() => location.reload(), 1000);
                    }
                }
            });
        }
    });

    $('#warehouseForm').on('submit', function (e) {
        e.preventDefault();
        
        var idVal = $('#WarehouseId').val();
        var url = (idVal === "0" || idVal === "") ? '/Warehouse/Create' : '/Warehouse/Edit';
        
        $.ajax({
            url: url,
            type: 'POST',
            data: $(this).serialize(), // Send standard form data
            success: function (res) {
                if (res.success) {
                    showToast(res.message, 'success');
                    closeModal('addWarehouseModal');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(res.message || 'حدث خطأ أثناء الحفظ', 'error');
                    console.error("Server returned false:", res);
                }
            },
            error: function (xhr, status, error) {
                showToast('حدث خطأ في الاتصال بالخادم، راجع الـ Console', 'error');
                console.error("AJAX Error:", xhr.responseText);
            }
        });
    });
    
    function openAddWarehouseModal() {
        document.getElementById('warehouseForm').reset();
        $('#WarehouseId').val('0');
        openModal('addWarehouseModal');
    }

    function editWarehouse(id, name, code, phone, address, isActive) {
        document.getElementById('warehouseForm').reset();
        $('#WarehouseId').val(id);
        $('input[name="Name"]').val(name);
        $('input[name="Code"]').val(code);
        $('input[name="Phone"]').val(phone);
        $('textarea[name="Address"]').val(address);
        $('select[name="IsActive"]').val(isActive.toLowerCase() === 'true' ? 'true' : 'false');
        openModal('addWarehouseModal');
    }
</script>
}
