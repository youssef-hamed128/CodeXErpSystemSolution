@{
    ViewBag.Title = "الصفحة الرئيسية";
}

@section Styles {
  <style>
    /* Dashboard specific rich aesthetics */
    .dashboard-header {
      background: linear-gradient(135deg, var(--primary) 0%, #3b82f6 100%);
      border-radius: 12px;
      padding: 30px;
      color: white;
      margin-bottom: 25px;
      box-shadow: 0 10px 30px rgba(26, 86, 219, 0.2);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .dashboard-header h1 {
      color: white;
      margin: 0 0 5px 0;
      font-size: 1.8rem;
    }
    .dashboard-header p {
      color: rgba(255,255,255,0.8);
      margin: 0;
      font-size: 1rem;
    }
    .dashboard-header-actions .btn {
      background: rgba(255,255,255,0.2);
      border: 1px solid rgba(255,255,255,0.3);
      color: white;
      backdrop-filter: blur(5px);
      transition: all 0.3s ease;
    }
    .dashboard-header-actions .btn:hover {
      background: white;
      color: var(--primary);
    }
    
    .stats-grid-modern {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px;
      margin-bottom: 25px;
    }
    
    .stat-card-modern {
      background: white;
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.02);
      border: 1px solid var(--border-color);
      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
      position: relative;
      overflow: hidden;
    }
    .stat-card-modern:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 30px rgba(0,0,0,0.08);
      border-color: transparent;
    }
    .stat-card-modern::before {
      content: '';
      position: absolute;
      top: 0; right: 0; width: 4px; height: 100%;
    }
    .stat-card-modern.primary::before { background: var(--primary); }
    .stat-card-modern.success::before { background: var(--success); }
    .stat-card-modern.warning::before { background: var(--warning); }
    .stat-card-modern.danger::before { background: var(--danger); }
    .stat-card-modern.info::before { background: var(--info); }
    .stat-card-modern.purple::before { background: #8b5cf6; }

    .stat-card-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 15px;
    }
    .stat-card-icon {
      width: 48px; height: 48px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem;
    }
    .stat-card-modern.primary .stat-card-icon { background: var(--primary-light); color: var(--primary); }
    .stat-card-modern.success .stat-card-icon { background: var(--success-light); color: var(--success); }
    .stat-card-modern.warning .stat-card-icon { background: var(--warning-light); color: var(--warning); }
    .stat-card-modern.danger .stat-card-icon { background: var(--danger-light); color: var(--danger); }
    .stat-card-modern.info .stat-card-icon { background: var(--info-light); color: var(--info); }
    .stat-card-modern.purple .stat-card-icon { background: #ede9fe; color: #8b5cf6; }

    .stat-card-trend {
      font-size: 0.85rem; font-weight: 600; padding: 4px 8px; border-radius: 20px;
    }
    .trend-up { background: var(--success-light); color: var(--success); }
    .trend-down { background: var(--danger-light); color: var(--danger); }

    .stat-card-value {
      font-size: 1.8rem; font-weight: 700; color: var(--text-color); line-height: 1.2; margin-bottom: 5px;
    }
    .stat-card-title {
      color: var(--text-muted); font-size: 0.95rem; font-weight: 500;
    }

    .charts-row {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 20px;
      margin-bottom: 25px;
    }
    @@media(max-width: 992px) { .charts-row { grid-template-columns: 1fr; } }
    
    .modern-panel {
      background: white; border-radius: 12px; border: 1px solid var(--border-color);
      box-shadow: 0 4px 6px rgba(0,0,0,0.02); padding: 20px;
    }
    .panel-header {
      display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;
      border-bottom: 1px solid #f1f5f9; padding-bottom: 15px;
    }
    .panel-title { margin: 0; font-size: 1.1rem; font-weight: 700; color: var(--text-color); }
    
    /* Quick Actions */
    .quick-actions {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px;
    }
    .action-box {
      text-align: center; padding: 15px 10px; border-radius: 10px;
      background: #f8fafc; border: 1px solid #e2e8f0; cursor: pointer;
      transition: all 0.2s; text-decoration: none; color: var(--text-color);
    }
    .action-box:hover {
      background: var(--primary); color: white; transform: translateY(-3px); box-shadow: 0 5px 15px rgba(26,86,219,0.2);
    }
    .action-box i { font-size: 1.5rem; margin-bottom: 10px; display: block; color: var(--primary); }
    .action-box:hover i { color: white; }
    .action-box span { font-size: 0.85rem; font-weight: 600; }
  </style>
}

<!-- Hero Header -->
<div class="dashboard-header">
  <div>
    <h1>مرحباً بك في النظام المالي <i class="fas fa-hand-wave" style="color: #fbbf24;"></i></h1>
    <p>إليك نظرة عامة شاملة على أداء اليوم: <span id="currentDateStr" style="font-weight:bold;"></span></p>
  </div>
  <div class="dashboard-header-actions">
    <button class="btn btn-sm" onclick="showToast('جاري تحديث البيانات...','info')"><i class="fas fa-sync-alt"></i> تحديث</button>
    <button class="btn btn-sm" onclick="window.print()"><i class="fas fa-print"></i> تقرير يومي</button>
  </div>
</div>

<!-- KPIs -->
<div class="stats-grid-modern">
  <!-- 1 -->
  <div class="stat-card-modern primary">
    <div class="stat-card-top">
      <div class="stat-card-icon"><i class="fas fa-chart-line"></i></div>
      <div class="stat-card-trend trend-up"><i class="fas fa-arrow-up"></i> 12%</div>
    </div>
    <div class="stat-card-value">@ViewBag.TotalSales?.ToString("N2")</div>
    <div class="stat-card-title">إجمالي المبيعات (الشهر)</div>
  </div>
  <!-- 2 -->
  <div class="stat-card-modern success">
    <div class="stat-card-top">
      <div class="stat-card-icon"><i class="fas fa-shopping-cart"></i></div>
      <div class="stat-card-trend trend-up"><i class="fas fa-arrow-up"></i> 8%</div>
    </div>
    <div class="stat-card-value">@ViewBag.TotalPurchases?.ToString("N2")</div>
    <div class="stat-card-title">إجمالي المشتريات (الشهر)</div>
  </div>
  <!-- 3 -->
  <div class="stat-card-modern warning">
    <div class="stat-card-top">
      <div class="stat-card-icon"><i class="fas fa-hand-holding-usd"></i></div>
      <div class="stat-card-trend trend-down"><i class="fas fa-arrow-down"></i> 3%</div>
    </div>
    <div class="stat-card-value">@ViewBag.TotalReceivable?.ToString("N2")</div>
    <div class="stat-card-title">ذمم مدينة (مستحقات لنا)</div>
  </div>
  <!-- 4 -->
  <div class="stat-card-modern danger">
    <div class="stat-card-top">
      <div class="stat-card-icon"><i class="fas fa-file-invoice-dollar"></i></div>
      <div class="stat-card-trend trend-up"><i class="fas fa-arrow-up"></i> 5%</div>
    </div>
    <div class="stat-card-value">@ViewBag.TotalPayable?.ToString("N2")</div>
    <div class="stat-card-title">ذمم دائنة (مستحقات علينا)</div>
  </div>
</div>

<!-- Charts & Quick Actions -->
<div class="charts-row">
  <!-- Chart -->
  <div class="modern-panel">
    <div class="panel-header">
      <h3 class="panel-title"><i class="fas fa-chart-area" style="color:var(--primary);margin-left:8px;"></i> المبيعات مقابل المشتريات</h3>
      <select class="form-select" style="width: auto; padding: 4px 30px 4px 10px; font-size: 0.85rem;">
        <option>آخر 6 أشهر</option>
        <option>هذا العام</option>
      </select>
    </div>
    <div style="height: 300px; width: 100%;">
      <canvas id="mainChart"></canvas>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="modern-panel">
    <div class="panel-header">
      <h3 class="panel-title"><i class="fas fa-bolt" style="color:#eab308;margin-left:8px;"></i> إجراءات سريعة</h3>
    </div>
    <div class="quick-actions" style="grid-template-columns: 1fr 1fr;">
      <a href="~/SalesInvoice/Create" class="action-box">
        <i class="fas fa-file-invoice"></i>
        <span>فاتورة مبيعات</span>
      </a>
      <a href="~/PurchaseInvoice/Create" class="action-box">
        <i class="fas fa-shopping-cart"></i>
        <span>فاتورة مشتريات</span>
      </a>
      <a href="~/Accounting/JournalEntries" class="action-box">
        <i class="fas fa-balance-scale"></i>
        <span>قيد يومية</span>
      </a>
      <a href="~/Accounting/Payments" class="action-box">
        <i class="fas fa-money-check-alt"></i>
        <span>سند قبض/صرف</span>
      </a>
      <a href="~/Inventory/StockTransfer" class="action-box">
        <i class="fas fa-exchange-alt"></i>
        <span>نقل مخزون</span>
      </a>
      <a href="~/Reports/Index" class="action-box">
        <i class="fas fa-chart-pie"></i>
        <span>مركز التقارير</span>
      </a>
    </div>
  </div>
</div>

<!-- Recent Transactions Table -->
<div class="modern-panel">
  <div class="panel-header">
    <h3 class="panel-title"><i class="fas fa-history" style="color:var(--secondary);margin-left:8px;"></i> أحدث العمليات</h3>
    <button class="btn btn-outline-secondary btn-sm" onclick="showToast('جاري التحديث...','info')">عرض الكل</button>
  </div>
  <div class="table-responsive">
    <table class="table">
      <thead>
        <tr>
          <th>الرقم</th>
          <th>النوع</th>
          <th>الطرف الآخر</th>
          <th>التاريخ</th>
          <th>المبلغ</th>
          <th>الحالة</th>
          <th>إجراء</th>
        </tr>
      </thead>
      <tbody>
@foreach(var inv in ViewBag.RecentInvoices as IEnumerable<CodeXErpSystem.BLL.ViewModels.Invoice.InvoiceViewModel>)
{
  <tr>
    <td style="font-weight:700; color:var(--primary);">@inv.InvoiceNumber</td>
    <td>@(inv.Type == CodeXErpSystem.DAL.Entites.Enums.InvoiceType.Sales ? "فاتورة مبيعات" : "فاتورة مشتريات")</td>
    <td>@(inv.Type == CodeXErpSystem.DAL.Entites.Enums.InvoiceType.Sales ? inv.CustomerName : inv.SupplierName)</td>
    <td>@inv.Date.ToString("yyyy-MM-dd")</td>
    <td class="numeric">@inv.TotalAmount.ToString("N2")</td>
    <td><span class="badge @(inv.Status == CodeXErpSystem.DAL.Entites.Enums.InvoiceStatus.Paid ? "badge-success" : "badge-warning")">@inv.Status</span></td>
    <td class="table-actions">
      <button class="action-btn view" onclick="showPreview('معاينة الفاتورة')"><i class="fas fa-eye"></i></button>
    </td>
  </tr>
}
</tbody>
    </table>
  </div>
</div>

@section Scripts {
<script src="~/lib/chartjs/chart.umd.min.js"></script>

<script>
  // Set Date
  document.getElementById('currentDateStr').innerText = new Date().toLocaleDateString('ar-SA', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

  // Init Chart
  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => {
      const ctx = document.getElementById('mainChart').getContext('2d');
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: ['يناير', 'فبراير', 'مارس', 'أبريل', 'مايو', 'يونيو'],
          datasets: [
            {
              label: 'المبيعات',
              data: [65, 78, 90, 81, 112, 125],
              borderColor: '#1a56db',
              backgroundColor: 'rgba(26, 86, 219, 0.1)',
              borderWidth: 3,
              tension: 0.4,
              fill: true
            },
            {
              label: 'المشتريات',
              data: [40, 55, 60, 45, 70, 65],
              borderColor: '#057a55',
              backgroundColor: 'rgba(5, 122, 85, 0.1)',
              borderWidth: 3,
              tension: 0.4,
              fill: true
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: 'top', labels: { font: { family: 'Cairo' } } } },
          scales: {
            y: { beginAtZero: true, grid: { borderDash: [5, 5] } },
            x: { grid: { display: false } }
          }
        }
      });
    }, 500);
  });
</script>
}

