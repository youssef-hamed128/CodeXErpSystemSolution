@using System.Web
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>@ViewBag.Title | كوديكس ERP</title>
  
  <link href="~/lib/cairo/cairo.css" rel="stylesheet">
  <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css">
  
  <link rel="stylesheet" href="~/css/variables.css">
  <link rel="stylesheet" href="~/css/main.css">
  <link rel="stylesheet" href="~/css/layout.css">
  <link rel="stylesheet" href="~/css/components.css">

  @RenderSection("Styles", required: false)
</head>
<body class="rtl">

<!-- Sidebar -->
<nav class="sidebar" id="sidebar">
  <a class="sidebar-brand" href="~/Home/Index">
    <div class="sidebar-brand-icon"><i class="fas fa-chart-line"></i></div>
    <div class="sidebar-brand-text">
        <span class="sidebar-brand-name">كوديكس ERP</span>
        <span class="sidebar-brand-subtitle">نظام المحاسبة المتكامل</span>
    </div>
  </a>
  <div class="sidebar-nav-wrapper">
    <ul class="sidebar-nav">
      <li class="nav-section-label">الرئيسية</li>
      <li class="nav-item"><a class="nav-link" href="~/Home/Index"><span class="nav-icon"><i class="fas fa-home"></i></span><span class="nav-text">الصفحة الرئيسية</span></a></li>
      
      <li class="nav-section-label">المعاملات</li>
      <li class="nav-item">
        <div class="nav-link" data-submenu="s1">
          <span class="nav-icon"><i class="fas fa-file-invoice-dollar"></i></span>
          <span class="nav-text">المبيعات</span>
          <span class="nav-arrow"><i class="fas fa-chevron-left"></i></span>
        </div>
        <ul class="nav-submenu" id="s1">
          
          <li class="nav-item"><a class="nav-link" href="~/SalesInvoice/Index"><span class="nav-text">فواتير المبيعات</span></a></li>
        </ul>
      </li>
      <li class="nav-item">
        <div class="nav-link" data-submenu="s2">
          <span class="nav-icon"><i class="fas fa-shopping-cart"></i></span>
          <span class="nav-text">المشتريات</span>
          <span class="nav-arrow"><i class="fas fa-chevron-left"></i></span>
        </div>
        <ul class="nav-submenu" id="s2">
          
          <li class="nav-item"><a class="nav-link" href="~/PurchaseInvoice/Index"><span class="nav-text">فواتير المشتريات</span></a></li>
        </ul>
      </li>
      <li class="nav-item">
        <div class="nav-link" data-submenu="s3">
          <span class="nav-icon"><i class="fas fa-undo-alt"></i></span>
          <span class="nav-text">المرتجعات</span>
          <span class="nav-arrow"><i class="fas fa-chevron-left"></i></span>
        </div>
        <ul class="nav-submenu" id="s3">
          <li class="nav-item"><a class="nav-link" href="~/SalesReturn/Index"><span class="nav-text">مرتجعات البيع</span></a></li>
          <li class="nav-item"><a class="nav-link" href="~/PurchaseReturn/Index"><span class="nav-text">مرتجعات الشراء</span></a></li>
        </ul>
      </li>

      <li class="nav-section-label">المخزون</li>
      <li class="nav-item">
        <div class="nav-link" data-submenu="s4">
          <span class="nav-icon"><i class="fas fa-warehouse"></i></span>
          <span class="nav-text">المخازن والمنتجات</span>
          <span class="nav-arrow"><i class="fas fa-chevron-left"></i></span>
        </div>
        <ul class="nav-submenu" id="s4">
          <li class="nav-item"><a class="nav-link" href="~/Product/Index"><span class="nav-text">المنتجات</span></a></li>
          <li class="nav-item"><a class="nav-link" href="~/Warehouse/Index"><span class="nav-text">المستودعات</span></a></li>
          <li class="nav-item"><a class="nav-link" href="~/StockTransfer/Index"><span class="nav-text">تحويل المخزون</span></a></li>
          <li class="nav-item"><a class="nav-link" href="~/StockAdjustment/Index"><span class="nav-text">تسوية المخزون</span></a></li>
        </ul>
      </li>

      <li class="nav-section-label">المحاسبة</li>
      <li class="nav-item">
        <div class="nav-link" data-submenu="s5">
          <span class="nav-icon"><i class="fas fa-calculator"></i></span>
          <span class="nav-text">المحاسبة</span>
          <span class="nav-arrow"><i class="fas fa-chevron-left"></i></span>
        </div>
        <ul class="nav-submenu" id="s5">
          <li class="nav-item"><a class="nav-link" href="~/ChartOfAccounts/Index"><span class="nav-text">دليل الحسابات</span></a></li>
          <li class="nav-item"><a class="nav-link" href="~/JournalEntry/Index"><span class="nav-text">القيود اليومية</span></a></li>
          <li class="nav-item"><a class="nav-link" href="~/Payment/Index"><span class="nav-text">المدفوعات</span></a></li>
          <li class="nav-item"><a class="nav-link" href="~/Customer/Index"><span class="nav-text">العملاء</span></a></li>
          <li class="nav-item"><a class="nav-link" href="~/Supplier/Index"><span class="nav-text">الموردون</span></a></li>
          <li class="nav-item"><a class="nav-link" href="~/Expense/Index"><span class="nav-text">المصروفات</span></a></li>
        </ul>
      </li>

      <li class="nav-section-label">التحليل</li>
      <li class="nav-item"><a class="nav-link" href="~/Reports/Index"><span class="nav-icon"><i class="fas fa-chart-bar"></i></span><span class="nav-text">التقارير</span></a></li>
      
      <li class="nav-section-label">الإدارة</li>
      <li class="nav-item"><a class="nav-link" href="~/Settings/Index"><span class="nav-icon"><i class="fas fa-cog"></i></span><span class="nav-text">الإعدادات</span></a></li>
      <li class="nav-item"><a class="nav-link" href="~/Users/Index"><span class="nav-icon"><i class="fas fa-users-cog"></i></span><span class="nav-text">المستخدمون</span></a></li>
    </ul>
  </div>
  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div style="width:36px;height:36px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;flex-shrink:0;">أ</div>
      <div class="sidebar-user-info">
        <div class="sidebar-user-name">أحمد السعيد</div>
        <div class="sidebar-user-role">مدير النظام</div>
      </div>
    </div>
  </div>
</nav>
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!-- Main Content Wrapper -->
<div class="main-wrapper" id="mainWrapper">
  <!-- Navbar -->
  <header class="navbar">
    <div class="navbar-start">
      <button class="sidebar-toggle-btn" id="sidebarToggle"><i class="fas fa-bars"></i></button>
      <div class="navbar-search">
        <i class="fas fa-search navbar-search-icon"></i>
        <input type="text" class="navbar-search-input" id="globalSearch" placeholder="بحث سريع...">
      </div>
    </div>
    <div class="navbar-end">
      <div class="lang-switcher">
        <button class="lang-btn active" data-lang="ar">عربي</button>
        <button class="lang-btn" data-lang="en">EN</button>
      </div>
      <button class="theme-toggle navbar-btn" id="themeToggle"><i class="fas fa-moon"></i></button>
      
      <div style="position:relative;">
        <button class="navbar-btn" data-dropdown-toggle="notifDrop">
          <i class="fas fa-bell"></i>
          <span class="notification-badge">2</span>
        </button>
        <div class="notification-dropdown" id="notifDrop">
          <div class="notification-header"><span style="font-weight:600;">الإشعارات</span></div>
          <div class="notification-list" id="notificationList"></div>
        </div>
      </div>
      
      <div style="position:relative;">
        <button class="user-avatar-btn" data-dropdown-toggle="userDrop">
          <div class="user-info-text">
            <div class="user-name">أحمد السعيد</div>
            <div class="user-role">مدير النظام</div>
          </div>
          <div style="width:32px;height:32px;border-radius:50%;background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;">أ</div>
        </button>
        <div class="dropdown-menu" id="userDrop">
          <a class="dropdown-item" href="~/Users/Profile"><i class="fas fa-user-circle"></i><span>الملف الشخصي</span></a>
          <div class="dropdown-divider"></div>
          <a class="dropdown-item" href="#" style="color:var(--danger);"><i class="fas fa-sign-out-alt"></i><span>تسجيل الخروج</span></a>
        </div>
      </div>
    </div>
  </header>

  <!-- Page Content -->
  <main class="content-wrapper">
    @RenderBody()
  </main>
</div>

<!-- Global Modals & Toasts -->
<div class="modal-overlay" id="confirmModal">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h5 class="modal-title" id="confirmModalTitle"></h5>
      <button class="modal-close" data-modal-close="confirmModal"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" style="text-align:center;padding:var(--spacing-8);">
      <div class="confirm-icon danger" id="confirmIcon"><i class="fas fa-trash"></i></div>
      <p id="confirmMessage"></p>
    </div>
    <div class="modal-footer" style="justify-content:center;">
      <button class="btn btn-secondary" data-modal-close="confirmModal" id="confirmCancelBtn">إلغاء</button>
      <button class="btn btn-danger" id="confirmOkBtn">تأكيد الحذف</button>
    </div>
  </div>
</div>

<div class="toast-container"></div>

<!-- Global Scripts -->
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/js/app.js"></script>
<script src="~/js/datatable.js"></script>
@RenderSection("Scripts", required: false)

</body>
</html>


