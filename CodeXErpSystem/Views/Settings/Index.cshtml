@model CodeXErpSystem.BLL.ViewModels.Settings.CompanySettingsViewModel
@{ Layout = "_Layout"; }

<form asp-action="Index" asp-controller="Settings" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <nav class="breadcrumb">
        <div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div>
        <div class="breadcrumb-item active">الإعدادات العامة</div>
    </nav>
    <div class="page-header">
      <div class="page-header-left">
          <h1 class="page-title"><i class="fas fa-cogs" style="color:var(--primary);"></i> إعدادات النظام</h1>
      </div>
      <div class="page-header-right">
          <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ التغييرات</button>
      </div>
    </div>
    
    <div class="grid-2">
      <!-- Company Profile -->
      <div class="card" style="padding:var(--spacing-5);">
        <h3 style="font-size:var(--fs-base);font-weight:700;margin-bottom:var(--spacing-4);border-bottom:1px solid var(--border-color);padding-bottom:var(--spacing-3);"><i class="fas fa-building"></i> بيانات الشركة</h3>
        
        <div class="form-group">
            <label class="form-label">اسم الشركة</label>
            <input type="text" asp-for="CompanyName" class="form-control" placeholder="اسم الشركة">
            <span asp-validation-for="CompanyName" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label class="form-label">الرقم الضريبي (VAT)</label>
            <input type="text" asp-for="TaxNumber" class="form-control" dir="ltr">
        </div>
        <div class="form-group">
            <label class="form-label">السجل التجاري (CR)</label>
            <input type="text" asp-for="CommercialRegistration" class="form-control" dir="ltr">
        </div>
        <div class="form-group">
            <label class="form-label">رقم الهاتف</label>
            <input type="tel" asp-for="Phone" class="form-control" dir="ltr">
        </div>
        <div class="form-group">
            <label class="form-label">البريد الإلكتروني</label>
            <input type="email" asp-for="Email" class="form-control" dir="ltr">
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label class="form-label">العنوان</label>
            <textarea asp-for="NationalAddress" class="form-control" rows="2"></textarea>
        </div>
      </div>

      <!-- Financial Settings -->
      <div class="card" style="padding:var(--spacing-5);">
        <h3 style="font-size:var(--fs-base);font-weight:700;margin-bottom:var(--spacing-4);border-bottom:1px solid var(--border-color);padding-bottom:var(--spacing-3);"><i class="fas fa-money-bill-wave"></i> الإعدادات المالية</h3>
        
        <div class="form-group">
            <label class="form-label">العملة الأساسية</label>
            <select asp-for="BaseCurrency" class="form-select">
                <option value="EGP">الجنية المصري (EGP)</option>
                <option value="SAR">ريال سعودي (SAR)</option>
                <option value="USD">دولار أمريكي (USD)</option>
            </select>
        </div>
        <div class="form-group">
            <label class="form-label">نسبة ضريبة القيمة المضافة الافتراضية (%)</label>
            <input type="number" asp-for="DefaultTaxRate" class="form-control" step="0.01">
        </div>
        <div class="form-group">
            <label class="form-label">بداية السنة المالية</label>
            <input type="date" asp-for="FinancialYearStart" class="form-control" value="@Model.FinancialYearStart.ToString("yyyy-MM-dd")">
        </div>
        
        <h3 style="font-size:var(--fs-base);font-weight:700;margin-bottom:var(--spacing-4);margin-top:var(--spacing-6);border-bottom:1px solid var(--border-color);padding-bottom:var(--spacing-3);"><i class="fas fa-qrcode"></i> نظام الفاتورة الألكترونية</h3>
        
        <div class="form-group form-check">
            <input type="checkbox" asp-for="IsZatcaConnected" class="form-check-input" id="isZatcaConnected" />
            <label class="form-check-label" for="isZatcaConnected">متصل مع منصة الضرائب</label>
        </div>

        <div class="form-group mt-3">
            <label class="form-label">رمز التكامل (API Key)</label>
            <input type="password" asp-for="ZatcaApiKey" class="form-control">
        </div>
      </div>
    </div>
</form>

<div class="toast-container"></div>
<script src="~/js/app.js"></script>

@if(TempData["Success"] != null)
{
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            showToast('@TempData["Success"]', 'success');
        });
    </script>
}



