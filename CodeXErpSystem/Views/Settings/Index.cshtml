@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item active">الإعدادات العامة</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-cogs" style="color:var(--primary);"></i> إعدادات النظام</h1></div>
      <div class="page-header-right"><button class="btn btn-primary" onclick="showToast('تم حفظ الإعدادات بنجاح','success')"><i class="fas fa-save"></i> حفظ التغييرات</button></div>
    </div>
    
    <div class="grid-2">
      <!-- Company Profile -->
      <div class="card" style="padding:var(--spacing-5);">
        <h3 style="font-size:var(--fs-base);font-weight:700;margin-bottom:var(--spacing-4);border-bottom:1px solid var(--border-color);padding-bottom:var(--spacing-3);"><i class="fas fa-building"></i> بيانات الشركة</h3>
        <div class="form-group"><label class="form-label">اسم الشركة</label><input type="text" class="form-control" value="شركة CodeX Erp System للبرمجيات"></div>
        <div class="form-group"><label class="form-label">الرقم الضريبي (VAT)</label><input type="text" class="form-control" value="300123456700003" dir="ltr"></div>
        <div class="form-group"><label class="form-label">السجل التجاري (CR)</label><input type="text" class="form-control" value="1234567890" dir="ltr"></div>
        <div class="form-group"><label class="form-label">رقم الهاتف</label><input type="tel" class="form-control" value="+966 11 234 5678" dir="ltr"></div>
        <div class="form-group"><label class="form-label">البريد الإلكتروني</label><input type="email" class="form-control" value="info@codex-erp.sa" dir="ltr"></div>
        <div class="form-group"><label class="form-label">العنوان الوطني</label><textarea class="form-control" rows="2">الرياض، حي الصحافة، طريق الملك فهد</textarea></div>
      </div>

      <!-- Financial Settings -->
      <div class="card" style="padding:var(--spacing-5);">
        <h3 style="font-size:var(--fs-base);font-weight:700;margin-bottom:var(--spacing-4);border-bottom:1px solid var(--border-color);padding-bottom:var(--spacing-3);"><i class="fas fa-money-bill-wave"></i> الإعدادات المالية</h3>
        <div class="form-group"><label class="form-label">العملة الأساسية</label><select class="form-select"><option value="SAR" selected>ريال سعودي (SAR)</option><option value="USD">دولار أمريكي (USD)</option></select></div>
        <div class="form-group"><label class="form-label">نسبة ضريبة القيمة المضافة الافتراضية (%)</label><input type="number" class="form-control" value="15"></div>
        <div class="form-group"><label class="form-label">بداية السنة المالية</label><input type="date" class="form-control" value="2024-01-01"></div>
        
        <h3 style="font-size:var(--fs-base);font-weight:700;margin-bottom:var(--spacing-4);margin-top:var(--spacing-6);border-bottom:1px solid var(--border-color);padding-bottom:var(--spacing-3);"><i class="fas fa-qrcode"></i> تكامل الفوترة الإلكترونية (ZATCA)</h3>
        <div class="alert alert-success">
          <i class="fas fa-check-circle"></i> النظام متصل بنجاح مع منصة فاتورة (ZATCA).
        </div>
        <div class="form-group"><label class="form-label">رمز التكامل (API Key)</label><input type="password" class="form-control" value="********************************"></div>
      </div>
    </div>
  
<div class="toast-container"></div>
<script src="~/js/app.js"></script>



