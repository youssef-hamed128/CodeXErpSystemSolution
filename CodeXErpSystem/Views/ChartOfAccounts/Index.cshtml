@model IEnumerable<CodeXErpSystem.BLL.ViewModels.Accounting.AccountViewModel>
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item active">دليل الحسابات</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-sitemap" style="color:var(--info);"></i> دليل الحسابات (COA)</h1></div>
      <div class="page-header-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> تصدير</button>
        <button class="btn btn-info" onclick="openModal('addAccountModal')"><i class="fas fa-plus"></i> إضافة حساب</button>
      </div>
    </div>
    
    <div class="data-table-wrapper">
      <div class="filter-bar">
        <input type="text" class="form-control" placeholder="بحث باسم أو رقم الحساب..." style="max-width:300px;">
        <select class="form-select"><option value="">جميع أنواع الحسابات</option><option>الأصول</option><option>الخصوم</option><option>حقوق الملكية</option><option>الإيرادات</option><option>المصروفات</option></select>
      </div>
      <div class="table-responsive">
        <table class="data-table">
          <thead><tr><th>رقم الحساب</th><th>اسم الحساب</th><th>النوع</th><th>طبيعة الحساب</th><th>الرصيد الحالي</th><th class="center">الإجراءات</th></tr></thead>
          <tbody>
@foreach(var item in Model) {
            <tr>
              <td><span style="font-family:monospace;background:var(--bg-secondary);padding:2px 6px;border-radius:4px;color:var(--text-secondary);">@item.Code</span></td>
              <td style="font-weight:600;color:var(--text-primary);">@item.Name</td>
              <td>أصول</td>
              <td>الميزانية العمومية</td>
              <td class="numeric" style="font-weight:700;">@item.Balance.ToString("N2")</td>
              <td class="table-actions"><button class="action-btn edit" onclick="openEditModal(@item.Id, '@item.Code', '@item.Name')"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteRecord(@item.Id)"><i class="fas fa-trash"></i></button></td>
            </tr>
}
          </tbody>
        </table>
      </div>
    </div>
  <!-- Add Account Modal -->
<div class="modal-overlay" id="addAccountModal">
  <div class="modal modal-lg">
    <div class="modal-header"><h5 class="modal-title"><i class="fas fa-plus"></i> إضافة حساب جديد</h5><button class="modal-close" data-modal-close="addAccountModal"><i class="fas fa-times"></i></button></div>
    <form id="accountForm">
      <input type="hidden" name="Id" id="accountId" value="0" />
      <div class="modal-body">
        @Html.AntiForgeryToken()
        <div class="form-grid-2">
          <div class="form-group"><label class="form-label required">اسم الحساب</label><input type="text" class="form-control" name="Name" required></div>
          <div class="form-group"><label class="form-label required">رقم الحساب</label><input type="text" class="form-control" name="Code" dir="ltr" required></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-info"><i class="fas fa-save"></i> حفظ</button>
        <button type="button" class="btn btn-secondary" data-modal-close="addAccountModal">إلغاء</button>
      </div>
    </form>
  </div>
</div>

<div class="modal-overlay" id="confirmModal"><div class="modal modal-sm"><div class="modal-header"><h5 class="modal-title" id="confirmModalTitle"></h5><button class="modal-close" data-modal-close="confirmModal"><i class="fas fa-times"></i></button></div><div class="modal-body" style="text-align:center;padding:var(--spacing-8);"><div class="confirm-icon danger" id="confirmIcon"><i class="fas fa-trash"></i></div><p id="confirmMessage"></p></div><div class="modal-footer" style="justify-content:center;"><button class="btn btn-secondary" data-modal-close="confirmModal" id="confirmCancelBtn">إلغاء</button><button class="btn btn-danger" id="confirmOkBtn">تأكيد الحذف</button></div></div></div>
<div class="toast-container"></div>

@section Scripts {
<script>
function openEditModal(id, code, name) {
        document.getElementById('accountForm').reset();
        document.getElementById('accountId').value = id;
        document.querySelector('input[name="Code"]').value = code;
        document.querySelector('input[name="Name"]').value = name;
        openModal('addAccountModal');
    }

    function deleteRecord(id) {
        if(confirm('هل أنت متأكد من حذف هذا السجل؟')) {
            $.post('/ChartOfAccounts/Delete', { id: id }, function(res) {
                if(res.success) {
                    showToast(res.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(res.message, 'error');
                }
            });
        }
    }

    $('#accountForm').on('submit', function(e) {
        e.preventDefault();
        let id = $('#accountId').val();
        let url = id == 0 ? '/ChartOfAccounts/Create' : '/ChartOfAccounts/Edit';
        $.post(url, $(this).serialize(), function(res) {
            if(res.success) {
                showToast(res.message, 'success');
                closeModal('addAccountModal');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(res.message, 'error');
            }
        });
    });
</script>
}

