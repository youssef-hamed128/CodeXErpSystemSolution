@model CodeXErpSystem.BLL.ViewModels.Warehouses.StockAdjustmentViewModel
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="../Home/Index.html"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item"><a href="../Product/Index">المخزون</a></div><div class="breadcrumb-item active">تسوية المخزون</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-sliders-h" style="color:var(--warning);"></i> تسوية المخزون</h1></div>
    </div>
    
    <form id="adjustmentForm">
      <input type="hidden" name="Id" id="AdjustmentId" value="0" />
      <!-- @Html.AntiForgeryToken() -->
      <div class="invoice-layout">
        <div class="invoice-section">
          <div class="invoice-section-header"><i class="fas fa-info-circle"></i> بيانات التسوية</div>
          <div class="invoice-section-body">
            <div class="form-grid-3">
              <div class="form-group"><label class="form-label required">تاريخ التسوية</label><input type="date" class="form-control" name="AdjustmentDate" id="adjDate" required></div>
              <div class="form-group">
                <label class="form-label required">المستودع</label>
                <select class="form-select" name="WarehouseId" required>
                  @foreach(var wh in Model.Warehouses)
                  {
                    <option value="@wh.Id">@wh.Name</option>
                  }
                </select>
              </div>
              <div class="form-group"><label class="form-label required">سبب التسوية</label><select class="form-select" name="Reason"><option value="count">جرد دوري</option><option value="damage">تالف</option><option value="theft">سرقة / فقدان</option><option value="expiry">انتهاء صلاحية</option></select></div>
            </div>
          </div>
        </div>

        <div class="invoice-section">
          <div class="invoice-section-header"><i class="fas fa-boxes"></i> المنتجات</div>
          <div class="invoice-section-body" style="padding:0;">
            <div class="table-responsive">
              <table class="invoice-items-table">
                <thead><tr><th style="width:40%;">المنتج</th><th style="width:15%;">الكمية الحالية (حسب النظام)</th><th style="width:15%;">الكمية الفعلية</th><th style="width:15%;">الفرق</th><th style="width:10%;" class="center">×</th></tr></thead>
                <tbody id="adjItemsBody">
                  @for(int i = 0; i < Model.AdjustmentItems.Count(); i++) {
                    var item = Model.AdjustmentItems.ElementAt(i);
                  <tr>
                    <td>
                      <select class="form-select mb-1 category-select" onchange="filterAdjProducts(this, 'adj_existing_@i')">
                         <option value="">-- كل المجموعات --</option>
                         @foreach(var cat in Model.Categories) {
                             <option value="@cat.Id">@cat.Name</option>
                         }
                      </select>
                      <select class="form-select product-select" name="AdjustmentItems[@i].ProductId" id="adj_existing_@i" onchange="updateSystemQuantity(this.id)" required>
                        @foreach(var p in Model.Products) {
                          if (p.Id == item.ProductId) {
                            <option value="@p.Id" selected>@p.ProductName</option>
                          } else {
                            <option value="@p.Id">@p.ProductName</option>
                          }
                        }
                      </select>
                    </td>
                    <td class="numeric"><input type="number" class="form-control sys-qty" name="AdjustmentItems[@i].SystemQuantity" value="@item.SystemQuantity" readonly style="background:var(--bg-hover);"></td>
                    <td><input type="number" class="form-control actual-qty" name="AdjustmentItems[@i].ActualQuantity" value="@item.ActualQuantity" min="0" oninput="calculateDifference(this)"></td>
                    <td class="numeric diff-qty" style="color:var(--danger);font-weight:700;" dir="ltr">@item.Difference</td>
                    <td class="center"><button type="button" class="remove-row-btn" onclick="const r = this.closest('tr'); if(r){r.style.opacity=0;setTimeout(()=>r.remove(),300);}"><i class="fas fa-trash"></i></button></td>
                  </tr>
                  }
                </tbody>
              </table>
            </div>
            <div style="padding:var(--spacing-4);"><button type="button" class="add-line-btn" id="addAdjLine"><i class="fas fa-plus"></i> إضافة منتج</button></div>
          </div>
        </div>

        <div class="invoice-section">
          <div class="invoice-section-header"><i class="fas fa-sticky-note"></i> الملاحظات والاعتماد</div>
          <div class="invoice-section-body">
            <div class="form-group"><label class="form-label">ملاحظات توضيحية</label><textarea class="form-control" name="Notes" rows="2" placeholder="تفاصيل إضافية حول سبب التسوية..."></textarea></div>
          </div>
        </div>
      </div>
      <div class="invoice-action-bar no-print">
        <button type="submit" class="btn btn-warning"><i class="fas fa-check"></i> اعتماد التسوية</button>
        <a href="../Product/Index" class="btn btn-ghost" style="margin-right:auto;">إلغاء</a>
      </div>
    </form>
  <div class="modal-overlay" id="confirmModal"><div class="modal modal-sm"><div class="modal-header"><h5 class="modal-title" id="confirmModalTitle"></h5><button class="modal-close" data-modal-close="confirmModal"><i class="fas fa-times"></i></button></div><div class="modal-body" style="text-align:center;padding:var(--spacing-8);"><div class="confirm-icon danger" id="confirmIcon"><i class="fas fa-trash"></i></div><p id="confirmMessage"></p></div><div class="modal-footer" style="justify-content:center;"><button class="btn btn-secondary" data-modal-close="confirmModal" id="confirmCancelBtn">إلغاء</button><button class="btn btn-danger" id="confirmOkBtn">تأكيد الحذف</button></div></div></div>
<div class="toast-container"></div>

@section Scripts {
<script>
    var currentDeleteId = 0;
    
    function deleteRow(btn, type, id) {
        currentDeleteId = id;
        document.getElementById('confirmMessage').innerText = 'هل أنت متأكد من حذف ' + type + '؟';
        openModal('confirmModal');
    }

    document.getElementById('confirmOkBtn').addEventListener('click', function () {
        if (currentDeleteId > 0) {
            $.ajax({
                url: '/StockAdjustment/Delete/' + currentDeleteId,
                type: 'POST',
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        closeModal('confirmModal');
                        setTimeout(() => location.reload(), 1000);
                    }
                }
            });
        }
    });

    var productsList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Products));
    var categoriesList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Categories));
    var categoryOptions = categoriesList.map(c => `<option value="${c.Id}">${c.Name}</option>`).join('');
    
    let adjRowIndex = 0;

    $('#addAdjLine').on('click', function() {
        var trId = 'adj_row_' + adjRowIndex;
        var tr = `
            <tr>
                <td>
                    <select class="form-select mb-1" onchange="filterAdjProducts(this, '${trId}')">
                        <option value="">-- كل المجموعات --</option>
                        ${categoryOptions}
                    </select>
                    <select class="form-select product-select" name="AdjustmentItems[].ProductId" id="${trId}" onchange="updateSystemQuantity('${trId}')" required>
                        <option value="">-- اختر المنتج --</option>
                        ${productsList.map(p => `<option value="${p.Id}">${p.ProductName}</option>`).join('')}
                    </select>
                </td>
                <td class="numeric"><input type="number" class="form-control sys-qty" name="AdjustmentItems[].SystemQuantity" value="0" readonly style="background:var(--bg-hover);"></td>
                <td><input type="number" class="form-control actual-qty" name="AdjustmentItems[].ActualQuantity" value="0" min="0" oninput="calculateDifference(this)"></td>
                <td class="numeric diff-qty" style="color:var(--danger);font-weight:700;" dir="ltr">0</td>
                <td class="center">
                    <button type="button" class="remove-row-btn" onclick="const r = this.closest('tr'); if(r){r.style.opacity=0;setTimeout(()=>r.remove(),300);}">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            </tr>
        `;
        $('#adjItemsBody').append(tr);
        adjRowIndex++;
    });

    function filterAdjProducts(categorySelect, productSelectId) {
        let categoryId = categorySelect.value;
        let productSelect = $('#' + productSelectId);
        
        productSelect.empty();
        productSelect.append(new Option("-- اختر المنتج --", "", true, true));
        
        let filteredProducts = productsList;
        if (categoryId) {
            filteredProducts = productsList.filter(p => p.CategoryId == categoryId);
        }
        
        filteredProducts.forEach(p => {
            productSelect.append(new Option(p.ProductName, p.Id, false, false));
        });
        updateSystemQuantity(productSelectId);
    }

    function updateSystemQuantity(selectId) {
        let warehouseId = $('select[name="WarehouseId"]').val();
        let productSelect = $('#' + selectId);
        let productId = productSelect.val();
        
        let tr = productSelect.closest('tr');
        let sysQtyInput = tr.find('.sys-qty');

        if (!warehouseId || !productId) {
            sysQtyInput.val('0');
            calculateDifference(tr.find('.actual-qty')[0]);
            return;
        }

        let product = productsList.find(p => p.Id == productId);
        if (product && product.StockByWarehouse && product.StockByWarehouse[warehouseId] !== undefined) {
            let qty = product.StockByWarehouse[warehouseId];
            sysQtyInput.val(qty);
        } else {
            sysQtyInput.val('0');
        }
        calculateDifference(tr.find('.actual-qty')[0]);
    }

    function calculateDifference(actualQtyInput) {
        if (!actualQtyInput) return;
        let tr = $(actualQtyInput).closest('tr');
        let sysQty = parseFloat(tr.find('.sys-qty').val()) || 0;
        let actualQty = parseFloat($(actualQtyInput).val()) || 0;
        let diff = actualQty - sysQty;
        
        let diffCell = tr.find('.diff-qty');
        diffCell.text((diff > 0 ? '+' : '') + diff);
        if (diff < 0) {
            diffCell.css('color', 'var(--danger)');
        } else if (diff > 0) {
            diffCell.css('color', 'var(--success)');
        } else {
            diffCell.css('color', 'var(--text)');
        }
    }

    $('select[name="WarehouseId"]').on('change', function() {
        $('.product-select').each(function() {
            updateSystemQuantity($(this).attr('id'));
        });
    });

    $('#adjustmentForm').on('submit', function (e) {
        e.preventDefault();
        var data = {};
        $(this).serializeArray().forEach(item => {
            data[item.name] = item.value;
        });

        var url = data.Id == 0 ? '/StockAdjustment/Create' : '/StockAdjustment/Edit';
        
        $.ajax({
            url: url,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (res) {
                if (res.success) {
                    showToast(res.message, 'success');
                    setTimeout(() => window.location.href = '../Product/Index', 1500);
                }
            }
        });
    });
</script>
}
