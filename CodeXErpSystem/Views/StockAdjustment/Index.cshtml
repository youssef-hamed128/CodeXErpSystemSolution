@model CodeXErpSystem.BLL.ViewModels.Warehouses.StockAdjustmentViewModel
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="../Home/Index.html"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item"><a href="../Product/Index">المخزون</a></div><div class="breadcrumb-item active">تسوية المخزون</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-sliders-h" style="color:var(--warning);"></i> تسوية المخزون</h1></div>
    </div>
    
    <form id="adjustmentForm">
      <input type="hidden" name="Id" id="AdjustmentId" value="0" />
      <!-- @Html.AntiForgeryToken() -->
      <div class="invoice-layout">
        <div class="invoice-section">
          <div class="invoice-section-header"><i class="fas fa-info-circle"></i> بيانات التسوية</div>
          <div class="invoice-section-body">
            <div class="form-grid-3">
              <div class="form-group"><label class="form-label required">تاريخ التسوية</label><input type="date" class="form-control" name="AdjustmentDate" id="adjDate" required></div>
              <div class="form-group">
                <label class="form-label required">المستودع</label>
                <select class="form-select" name="WarehouseId" required>
                  @foreach(var wh in Model.Warehouses)
                  {
                    <option value="@wh.Id">@wh.Name</option>
                  }
                </select>
              </div>
              <div class="form-group"><label class="form-label required">سبب التسوية</label><select class="form-select" name="Reason"><option value="count">جرد دوري</option><option value="damage">تالف</option><option value="theft">سرقة / فقدان</option><option value="expiry">انتهاء صلاحية</option></select></div>
            </div>
          </div>
        </div>

        <div class="invoice-section">
          <div class="invoice-section-header"><i class="fas fa-boxes"></i> المنتجات</div>
          <div class="invoice-section-body" style="padding:0;">
            <div class="table-responsive">
              <table class="invoice-items-table">
                <thead><tr><th style="width:40%;">المنتج</th><th style="width:15%;">الكمية الحالية (حسب النظام)</th><th style="width:15%;">الكمية الفعلية</th><th style="width:15%;">الفرق</th><th style="width:10%;" class="center">×</th></tr></thead>
                <tbody id="adjItemsBody">
                  @foreach(var item in Model.AdjustmentItems) {
                  <tr>
                    <td>
                      <select class="form-select">
                        @foreach(var p in Model.Products) {
                          if (p.Id == item.ProductId) {
                            <option value="@p.Id" selected>@p.ProductName</option>
                          } else {
                            <option value="@p.Id">@p.ProductName</option>
                          }
                        }
                      </select>
                    </td>
                    <td class="numeric"><input type="text" class="form-control" value="@item.SystemQuantity" readonly style="background:var(--bg-hover);"></td>
                    <td><input type="number" class="form-control actual-qty" value="@item.ActualQuantity" min="0"></td>
                    <td class="numeric" style="color:var(--danger);font-weight:700;" dir="ltr">@item.Difference</td>
                    <td class="center"><button type="button" class="remove-row-btn" onclick="const r = this.closest('tr'); if(r){r.style.opacity=0;setTimeout(()=>r.remove(),300);}"><i class="fas fa-trash"></i></button></td>
                  </tr>
                  }
                </tbody>
              </table>
            </div>
            <div style="padding:var(--spacing-4);"><button type="button" class="add-line-btn" onclick="showToast('تمت الإضافة', 'success')"><i class="fas fa-plus"></i> إضافة منتج</button></div>
          </div>
        </div>

        <div class="invoice-section">
          <div class="invoice-section-header"><i class="fas fa-sticky-note"></i> الملاحظات والاعتماد</div>
          <div class="invoice-section-body">
            <div class="form-group"><label class="form-label">ملاحظات توضيحية</label><textarea class="form-control" name="Notes" rows="2" placeholder="تفاصيل إضافية حول سبب التسوية..."></textarea></div>
          </div>
        </div>
      </div>
      <div class="invoice-action-bar no-print">
        <button type="submit" class="btn btn-warning"><i class="fas fa-check"></i> اعتماد التسوية</button>
        <a href="../Product/Index" class="btn btn-ghost" style="margin-right:auto;">إلغاء</a>
      </div>
    </form>
  <div class="modal-overlay" id="confirmModal"><div class="modal modal-sm"><div class="modal-header"><h5 class="modal-title" id="confirmModalTitle"></h5><button class="modal-close" data-modal-close="confirmModal"><i class="fas fa-times"></i></button></div><div class="modal-body" style="text-align:center;padding:var(--spacing-8);"><div class="confirm-icon danger" id="confirmIcon"><i class="fas fa-trash"></i></div><p id="confirmMessage"></p></div><div class="modal-footer" style="justify-content:center;"><button class="btn btn-secondary" data-modal-close="confirmModal" id="confirmCancelBtn">إلغاء</button><button class="btn btn-danger" id="confirmOkBtn">تأكيد الحذف</button></div></div></div>
<div class="toast-container"></div>

@section Scripts {
<script>
    var currentDeleteId = 0;
    
    function deleteRow(btn, type, id) {
        currentDeleteId = id;
        document.getElementById('confirmMessage').innerText = 'هل أنت متأكد من حذف ' + type + '؟';
        openModal('confirmModal');
    }

    document.getElementById('confirmOkBtn').addEventListener('click', function () {
        if (currentDeleteId > 0) {
            $.ajax({
                url: '/StockAdjustment/Delete/' + currentDeleteId,
                type: 'POST',
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        closeModal('confirmModal');
                        setTimeout(() => location.reload(), 1000);
                    }
                }
            });
        }
    });

    $('#adjustmentForm').on('submit', function (e) {
        e.preventDefault();
        var data = {};
        $(this).serializeArray().forEach(item => {
            data[item.name] = item.value;
        });

        var url = data.Id == 0 ? '/StockAdjustment/Create' : '/StockAdjustment/Edit';
        
        $.ajax({
            url: url,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (res) {
                if (res.success) {
                    showToast(res.message, 'success');
                    setTimeout(() => window.location.href = '../Product/Index', 1500);
                }
            }
        });
    });
</script>
}
