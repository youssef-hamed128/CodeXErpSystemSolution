@model IEnumerable<CodeXErpSystem.BLL.ViewModels.Payments.PaymentViewModel>
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>المدفوعات والمقبوضات | CodeX Erp System</title>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css">
  <link rel="stylesheet" href="~/css/variables.css"><link rel="stylesheet" href="~/css/main.css"><link rel="stylesheet" href="~/css/layout.css"><link rel="stylesheet" href="~/css/components.css"><link rel="stylesheet" href="~/css/additions.css">
</head>
<body class="rtl">
<nav class="sidebar" id="sidebar">
  <a class="sidebar-brand" href="~/Home/Index"><div class="sidebar-brand-icon"><i class="fas fa-chart-line"></i></div><div class="sidebar-brand-text"><span class="sidebar-brand-name">CodeX Erp System</span></div></a>
  <div class="sidebar-nav-wrapper">      <ul class="sidebar-nav">
  <li class="nav-section-label">الرئيسية</li>
  <li class="nav-item"><a class="nav-link" href="~/Home/Index"><span class="nav-icon"><i class="fas fa-home"></i></span><span class="nav-text">الصفحة الرئيسية</span></a></li>
  
  <li class="nav-section-label">المبيعات</li>
  
  <li class="nav-item"><a class="nav-link" href="~/SalesInvoice/Index"><span class="nav-icon"><i class="fas fa-file-invoice-dollar"></i></span><span class="nav-text">فواتير المبيعات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/SalesReturn/Index"><span class="nav-icon"><i class="fas fa-undo"></i></span><span class="nav-text">مرتجعات المبيعات</span></a></li>

  <li class="nav-section-label">المشتريات</li>
  
  <li class="nav-item"><a class="nav-link" href="~/PurchaseInvoice/Index"><span class="nav-icon"><i class="fas fa-file-invoice"></i></span><span class="nav-text">فواتير المشتريات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/PurchaseReturn/Index"><span class="nav-icon"><i class="fas fa-undo-alt"></i></span><span class="nav-text">مرتجعات المشتريات</span></a></li>

  <li class="nav-section-label">المخزون</li>
  <li class="nav-item"><a class="nav-link" href="~/Inventory/Products"><span class="nav-icon"><i class="fas fa-box"></i></span><span class="nav-text">المنتجات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Inventory/Warehouses"><span class="nav-icon"><i class="fas fa-warehouse"></i></span><span class="nav-text">المستودعات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Inventory/StockTransfer"><span class="nav-icon"><i class="fas fa-exchange-alt"></i></span><span class="nav-text">نقل المخزون</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Inventory/StockAdjustment"><span class="nav-icon"><i class="fas fa-sliders-h"></i></span><span class="nav-text">تسوية المخزون</span></a></li>

  <li class="nav-section-label">المحاسبة</li>
  <li class="nav-item"><a class="nav-link" href="~/ChartOfAccounts/Index"><span class="nav-icon"><i class="fas fa-book"></i></span><span class="nav-text">دليل الحسابات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/JournalEntry/Index"><span class="nav-icon"><i class="fas fa-balance-scale"></i></span><span class="nav-text">القيود اليومية</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Payment/Index"><span class="nav-icon"><i class="fas fa-money-check-alt"></i></span><span class="nav-text">المدفوعات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Customer/Index"><span class="nav-icon"><i class="fas fa-users"></i></span><span class="nav-text">العملاء</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Supplier/Index"><span class="nav-icon"><i class="fas fa-truck"></i></span><span class="nav-text">الموردون</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Expense/Index"><span class="nav-icon"><i class="fas fa-receipt"></i></span><span class="nav-text">المصروفات</span></a></li>

  <li class="nav-section-label">التقارير</li>
  <li class="nav-item"><a class="nav-link" href="~/Reports/Index"><span class="nav-icon"><i class="fas fa-chart-line"></i></span><span class="nav-text">مركز التقارير</span></a></li>

  <li class="nav-section-label">الإعدادات</li>
  <li class="nav-item"><a class="nav-link" href="~/Users/Index"><span class="nav-icon"><i class="fas fa-users-cog"></i></span><span class="nav-text">المستخدمين والصلاحيات</span></a></li>
  <li class="nav-item"><a class="nav-link" href="~/Settings/Index"><span class="nav-icon"><i class="fas fa-cogs"></i></span><span class="nav-text">إعدادات النظام</span></a></li>
</ul>
</div>
</nav>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<div class="main-wrapper" id="mainWrapper">
  <header class="navbar"><div class="navbar-start"><button class="sidebar-toggle-btn" id="sidebarToggle"><i class="fas fa-bars"></i></button></div><div class="navbar-end"><div class="lang-switcher"><button class="lang-btn active" data-lang="ar">عربي</button></div><button class="theme-toggle navbar-btn" id="themeToggle"><i class="fas fa-moon"></i></button></div></header>

  <main class="content-wrapper">
    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item active">المدفوعات والمقبوضات</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-money-check-alt" style="color:var(--success);"></i> المدفوعات والمقبوضات</h1></div>
      <div class="page-header-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> تصدير</button>
      </div>
    </div>
    
    <div class="tabs" data-tab-group="paymentTabs">
      <button class="tab active" data-tab="receivedTab">سندات القبض (من العملاء)</button>
      <button class="tab" data-tab="madeTab">سندات الصرف (للموردين)</button>
    </div>

    <!-- Received Payments -->
    <div class="tab-panel active" id="receivedTab">
      <div class="data-table-wrapper">
        <div class="filter-bar">
          <input type="text" class="form-control" placeholder="رقم السند أو العميل..." style="max-width:280px;">
          <input type="date" class="form-control">
          <button class="btn btn-success" style="margin-right:auto;" onclick="openModal('addPaymentModal')"><i class="fas fa-plus"></i> سند قبض جديد</button>
        </div>
        <div class="table-responsive">
          <table class="data-table">
            <thead><tr><th>رقم السند</th><th>التاريخ</th><th>المبلغ</th><th>طريقة الدفع</th><th>المرجع</th><th>الحالة</th><th class="center">الإجراءات</th></tr></thead>
            <tbody>
@foreach(var item in Model) {
            <tr>
              <td style="font-weight:600;color:var(--primary);">#@item.ReceiptNumber</td>
              <td>@item.Date.ToString("yyyy-MM-dd")</td>
              <td class="numeric" style="font-weight:700;color:var(--success);">@item.Amount.ToString("N2")</td>
              <td>@item.PaymentMethod</td>
              <td>@item.Reference</td>
              <td><span class="badge badge-success">مكتمل</span></td>
              <td class="table-actions"><button class="action-btn edit" onclick="openEditModal(@item.Id, '@item.ReceiptNumber', '@item.Date.ToString("yyyy-MM-dd")', @item.Amount, '@item.PaymentMethod', '@item.Reference')"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteRecord(@item.Id)"><i class="fas fa-trash"></i></button></td>
            </tr>
}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Made Payments -->
    <div class="tab-panel" id="madeTab">
      <div class="data-table-wrapper">
        <div class="filter-bar">
          <input type="text" class="form-control" placeholder="رقم السند أو المورد..." style="max-width:280px;">
          <input type="date" class="form-control">
          <button class="btn btn-danger" style="margin-right:auto;" onclick="openModal('addPaymentModal')"><i class="fas fa-plus"></i> سند صرف جديد</button>
        </div>
        <div class="table-responsive">
          <table class="data-table">
            <thead><tr><th>رقم السند</th><th>التاريخ</th><th>المورد</th><th>المبلغ</th><th>طريقة الدفع</th><th>رقم الفاتورة (المرجع)</th><th>الحالة</th></tr></thead>
            <tbody>
            </tbody>
          </table>
        </div>
      </div>
    </div>

  </main>
<div class="modal-overlay" id="addPaymentModal">
  <div class="modal modal-md">
    <div class="modal-header">
      <h5 class="modal-title" id="addPaymentModalTitle"><i class="fas fa-money-check-alt"></i> سند قبض / صرف جديد</h5>
      <button class="modal-close" data-modal-close="addPaymentModal"><i class="fas fa-times"></i></button>
    </div>
    <form id="paymentForm">
      <input type="hidden" name="Id" id="paymentId" value="0" />
      <div class="modal-body">
        @Html.AntiForgeryToken()
        <div class="form-grid-2">
          <div class="form-group" style="grid-column: span 2;">
            <label class="form-label required">رقم السند</label>
            <input type="text" class="form-control" name="ReceiptNumber" required>
          </div>
          <div class="form-group">
            <label class="form-label required">التاريخ</label>
            <input type="date" class="form-control" name="Date" required>
          </div>
          <div class="form-group">
            <label class="form-label required">المبلغ</label>
            <input type="number" class="form-control" name="Amount" placeholder="0.00" required>
          </div>
          <div class="form-group">
            <label class="form-label required">طريقة الدفع</label>
            <select class="form-select" name="PaymentMethod">
              <option value="cash">نقداً</option>
              <option value="bank">تحويل بنكي</option>
              <option value="check">شيك</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label required">المرجع</label>
            <input type="text" class="form-control" name="Reference">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> حفظ</button>
        <button type="button" class="btn btn-secondary" data-modal-close="addPaymentModal">إلغاء</button>
      </div>
    </form>
  </div>
</div>
<div class="toast-container"></div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/js/app.js"></script><script src="~/js/datatable.js"></script>
<script>
    function openEditModal(id, receiptNumber, date, amount, paymentMethod, reference) {
        document.getElementById('paymentForm').reset();
        document.getElementById('paymentId').value = id;
        document.querySelector('input[name="ReceiptNumber"]').value = receiptNumber;
        document.querySelector('input[name="Date"]').value = date;
        document.querySelector('input[name="Amount"]').value = amount;
        document.querySelector('select[name="PaymentMethod"]').value = paymentMethod;
        document.querySelector('input[name="Reference"]').value = reference;
        openModal('addPaymentModal');
    }

    function deleteRecord(id) {
        if(confirm('هل أنت متأكد من حذف هذا السجل؟')) {
            $.post('/Payment/Delete', { id: id }, function(res) {
                if(res.success) {
                    showToast(res.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(res.message, 'error');
                }
            });
        }
    }

    $('#paymentForm').on('submit', function(e) {
        e.preventDefault();
        let id = $('#paymentId').val();
        let url = id == 0 ? '/Payment/Create' : '/Payment/Edit';
        $.post(url, $(this).serialize(), function(res) {
            if(res.success) {
                showToast(res.message, 'success');
                closeModal('addPaymentModal');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(res.message, 'error');
            }
        });
    });
</script>
</body>
</html>

