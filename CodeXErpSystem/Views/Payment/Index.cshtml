@model IEnumerable<CodeXErpSystem.BLL.ViewModels.Payments.PaymentViewModel>
@{ Layout = "_Layout"; }

    <nav class="breadcrumb"><div class="breadcrumb-item"><a href="~/Home/Index"><i class="fas fa-home"></i> الرئيسية</a></div><div class="breadcrumb-item active">المدفوعات والمقبوضات</div></nav>
    <div class="page-header">
      <div class="page-header-left"><h1 class="page-title"><i class="fas fa-money-check-alt" style="color:var(--success);"></i> المدفوعات والمقبوضات</h1></div>
      <div class="page-header-right">
        <button class="btn btn-outline-secondary btn-sm" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> تصدير</button>
      </div>
    </div>
    
    <div class="tabs" data-tab-group="paymentTabs">
      <button class="tab active" data-tab="receivedTab">سندات القبض (من العملاء)</button>
      <button class="tab" data-tab="madeTab">سندات الصرف (للموردين)</button>
    </div>

    <!-- Received Payments -->
    <div class="tab-panel active" id="receivedTab">
      <div class="data-table-wrapper">
        <div class="filter-bar">
          <input type="text" class="form-control" placeholder="رقم السند أو العميل..." style="max-width:280px;">
          <input type="date" class="form-control">
          <button class="btn btn-success" style="margin-right:auto;" onclick="openAddPaymentModal('Customer')"><i class="fas fa-plus"></i> سند قبض جديد</button>
        </div>
        <div class="table-responsive">
          <table class="data-table">
            <thead><tr><th>رقم السند</th><th>التاريخ</th><th>العميل</th><th>المبلغ</th><th>طريقة الدفع</th><th>المرجع</th><th>الحالة</th><th class="center">الإجراءات</th></tr></thead>
            <tbody>
@foreach(var item in Model.Where(m => m.CustomerId != null || (m.SupplierId == null && m.Reference == null))) {
            <tr>
              <td style="font-weight:600;color:var(--primary);">#@item.ReceiptNumber</td>
              <td>@item.Date.ToString("yyyy-MM-dd")</td>
              <td>@(item.CustomerName ?? "عميل عام")</td>
              <td class="numeric" style="font-weight:700;color:var(--success);">@item.Amount.ToString("N2")</td>
              <td>
                @if(item.PaymentMethod == CodeXErpSystem.DAL.Entites.Enums.PaymentMethod.Cash) { <span>نقدي</span> }
                else if(item.PaymentMethod == CodeXErpSystem.DAL.Entites.Enums.PaymentMethod.BankTransfer) { <span>تحويل بنكي</span> }
                else if(item.PaymentMethod == CodeXErpSystem.DAL.Entites.Enums.PaymentMethod.CreaditCard) { <span>بطاقة ائتمان</span> }
                else { <span>شيك</span> }
              </td>
              <td>@item.Reference</td>
              <td><span class="badge badge-success">مكتمل</span></td>
              <td class="table-actions"><button class="action-btn edit" onclick="openEditModal(@item.Id, '@item.ReceiptNumber', '@item.Date.ToString("yyyy-MM-dd")', @item.Amount, '@item.PaymentMethod', '@(item.Reference ?? "")', @(item.CustomerId?.ToString() ?? "null"), @(item.SupplierId?.ToString() ?? "null"))"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteRecord(@item.Id)"><i class="fas fa-trash"></i></button></td>
            </tr>
}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Made Payments -->
    <div class="tab-panel" id="madeTab">
      <div class="data-table-wrapper">
        <div class="filter-bar">
          <input type="text" class="form-control" placeholder="رقم السند أو المورد..." style="max-width:280px;">
          <input type="date" class="form-control">
          <button class="btn btn-danger" style="margin-right:auto;" onclick="openAddPaymentModal('Supplier')"><i class="fas fa-plus"></i> سند صرف جديد</button>
        </div>
        <div class="table-responsive">
          <table class="data-table">
            <thead><tr><th>رقم السند</th><th>التاريخ</th><th>المورد</th><th>المبلغ</th><th>طريقة الدفع</th><th>رقم الفاتورة (المرجع)</th><th>الحالة</th><th class="center">الإجراءات</th></tr></thead>
            <tbody>
@foreach(var item in Model.Where(m => m.SupplierId != null || (m.CustomerId == null && m.Reference != null))) {
            <tr>
              <td style="font-weight:600;color:var(--danger);">#@item.ReceiptNumber</td>
              <td>@item.Date.ToString("yyyy-MM-dd")</td>
              <td>@(item.SupplierName ?? "مورد عام")</td>
              <td class="numeric" style="font-weight:700;color:var(--danger);">@item.Amount.ToString("N2")</td>
              <td>
                @if(item.PaymentMethod == CodeXErpSystem.DAL.Entites.Enums.PaymentMethod.Cash) { <span>نقدي</span> }
                else if(item.PaymentMethod == CodeXErpSystem.DAL.Entites.Enums.PaymentMethod.BankTransfer) { <span>تحويل بنكي</span> }
                else if(item.PaymentMethod == CodeXErpSystem.DAL.Entites.Enums.PaymentMethod.CreaditCard) { <span>بطاقة ائتمان</span> }
                else { <span>شيك</span> }
              </td>
              <td>@item.Reference</td>
              <td><span class="badge badge-success">مكتمل</span></td>
              <td class="table-actions"><button class="action-btn edit" onclick="openEditModal(@item.Id, '@item.ReceiptNumber', '@item.Date.ToString("yyyy-MM-dd")', @item.Amount, '@item.PaymentMethod', '@(item.Reference ?? "")', @(item.CustomerId?.ToString() ?? "null"), @(item.SupplierId?.ToString() ?? "null"))"><i class="fas fa-edit"></i></button><button class="action-btn delete" onclick="deleteRecord(@item.Id)"><i class="fas fa-trash"></i></button></td>
            </tr>
}
            </tbody>
          </table>
        </div>
      </div>
    </div>

<div class="modal-overlay" id="addPaymentModal">
  <div class="modal modal-md">
    <div class="modal-header"><h5 class="modal-title" id="paymentModalTitle"><i class="fas fa-money-check-alt"></i> سند جديد</h5><button class="modal-close" data-modal-close="addPaymentModal"><i class="fas fa-times"></i></button></div>
    <form id="paymentForm">
      <input type="hidden" name="Id" id="paymentId" value="0" />
      <div class="modal-body">
        <div class="form-grid-2">
          <div class="form-group"><label class="form-label required">رقم السند</label><input type="text" class="form-control" name="ReceiptNumber" id="receiptNumberInput" readonly placeholder="تلقائي"></div>
          <div class="form-group"><label class="form-label required">التاريخ</label><input type="date" class="form-control" name="Date" id="dateInput" required></div>
          
          <div class="form-group" id="customerGroup"><label class="form-label required">العميل</label>
            <select class="form-select" name="CustomerId" id="customerSelect">
              <option value="">-- اختر العميل --</option>
              @foreach(var c in ViewBag.Customers) { <option value="@c.Id">@c.Name</option> }
            </select>
          </div>
          <div class="form-group" id="supplierGroup" style="display:none;"><label class="form-label required">المورد</label>
            <select class="form-select" name="SupplierId" id="supplierSelect">
              <option value="">-- اختر المورد --</option>
              @foreach(var s in ViewBag.Suppliers) { <option value="@s.Id">@s.Name</option> }
            </select>
          </div>

          <div class="form-group"><label class="form-label required">المبلغ</label><input type="number" class="form-control" name="Amount" step="0.01" min="0" required></div>
          <div class="form-group"><label class="form-label required">طريقة الدفع</label>
            <select class="form-select" name="PaymentMethod" required>
              <option value="Cash">نقدي</option>
              <option value="BankTransfer">تحويل بنكي</option>
              <option value="CreaditCard">بطاقة ائتمان</option>
              <option value="Check">شيك</option>
            </select>
          </div>
          <div class="form-group" style="grid-column:span 2;"><label class="form-label">المرجع / ملاحظات</label><input type="text" class="form-control" name="Reference"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> حفظ</button>
        <button type="button" class="btn btn-secondary" data-modal-close="addPaymentModal">إلغاء</button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
<script>
    function openAddPaymentModal(type) {
        document.getElementById('paymentForm').reset();
        document.getElementById('paymentId').value = 0;
        
        let title = type === 'Supplier' ? '<i class="fas fa-money-check-alt"></i> إضافة سند صرف (لمورد)' : '<i class="fas fa-money-check-alt"></i> إضافة سند قبض (من عميل)';
        document.getElementById('paymentModalTitle').innerHTML = title;
        
        document.getElementById('receiptNumberInput').value = 'تلقائي';
        document.getElementById('dateInput').valueAsDate = new Date();
        
        if(type === 'Supplier') {
            document.getElementById('customerGroup').style.display = 'none';
            document.getElementById('supplierGroup').style.display = 'block';
            document.getElementById('customerSelect').required = false;
            document.getElementById('customerSelect').value = '';
            document.getElementById('supplierSelect').required = true;
        } else {
            document.getElementById('customerGroup').style.display = 'block';
            document.getElementById('supplierGroup').style.display = 'none';
            document.getElementById('customerSelect').required = true;
            document.getElementById('supplierSelect').required = false;
            document.getElementById('supplierSelect').value = '';
        }
        
        openModal('addPaymentModal');
    }

    function openEditModal(id, receiptNumber, date, amount, paymentMethod, reference, customerId, supplierId) {
        document.getElementById('paymentForm').reset();
        document.getElementById('paymentId').value = id;
        document.getElementById('paymentModalTitle').innerHTML = '<i class="fas fa-edit"></i> تعديل السند';
        document.querySelector('input[name="ReceiptNumber"]').value = receiptNumber;
        document.querySelector('input[name="Date"]').value = date;
        document.querySelector('input[name="Amount"]').value = amount;
        document.querySelector('select[name="PaymentMethod"]').value = paymentMethod;
        document.querySelector('input[name="Reference"]').value = reference;

        if (supplierId) {
            document.getElementById('customerGroup').style.display = 'none';
            document.getElementById('supplierGroup').style.display = 'block';
            document.getElementById('customerSelect').required = false;
            document.getElementById('customerSelect').value = '';
            document.getElementById('supplierSelect').required = true;
            document.getElementById('supplierSelect').value = supplierId;
        } else {
            document.getElementById('customerGroup').style.display = 'block';
            document.getElementById('supplierGroup').style.display = 'none';
            document.getElementById('customerSelect').required = true;
            document.getElementById('supplierSelect').required = false;
            document.getElementById('supplierSelect').value = '';
            document.getElementById('customerSelect').value = customerId || '';
        }

        openModal('addPaymentModal');
    }

    function deleteRecord(id) {
        if(confirm('هل أنت متأكد من حذف هذا السجل؟')) {
            $.post('/Payment/Delete', { id: id }, function(res) {
                if(res.success) {
                    showToast(res.message, 'success');
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showToast(res.message, 'error');
                }
            });
        }
    }

    $('#paymentForm').on('submit', function(e) {
        e.preventDefault();
        let id = $('#paymentId').val();
        let url = id == 0 ? '/Payment/Create' : '/Payment/Edit';
        $.post(url, $(this).serialize(), function(res) {
            if(res.success) {
                showToast(res.message, 'success');
                closeModal('addPaymentModal');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(res.message, 'error');
            }
        });
    });
</script>
}

